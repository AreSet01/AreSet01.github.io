---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { formatDate, sortPostsByDate } from '../utils/date';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = sortPostsByDate(allPosts);
const latestPost = posts[0];
const totalTags = new Set(posts.flatMap(post => post.data.tags ?? [])).size;
const latestYear = latestPost ? new Date(latestPost.data.pubDate).getFullYear() : new Date().getFullYear();
---

<BaseLayout title="梦付千秋 - 日常记录与技术分享">
  <Header />
  <main class="container-wide flex-1 pb-12 pt-10 md:pb-16 md:pt-14">
    <section class="home-hero reveal-up">
      <div class="home-hero-copy">
        <p class="eyebrow">Digital Garden</p>
        <h1 class="home-hero-title">
          发发牢骚，写写无关紧要小教程の小破网站
        </h1>
        <p class="home-hero-desc">
          也就随便分享一点小知识呀，一些行业看法呀，或是说些愤青言论等
        </p>
        <div class="home-actions">
          {latestPost && <a href={`/posts/${latestPost.id}`} class="btn-primary">阅读最新文章</a>}
          <a href="/archive" class="btn-secondary">浏览全部文章</a>
        </div>
      </div>

      <aside class="home-rail" aria-label="站点概览">
        <div class="home-stat">
          <span>文章数量</span>
          <strong>{posts.length}</strong>
        </div>
        <div class="home-stat">
          <span>标签数量</span>
          <strong>{totalTags}</strong>
        </div>
        <div class="home-stat">
          <span>最近更新</span>
          <strong>{latestYear}</strong>
        </div>
      </aside>
    </section>

    <section class="home-digest">
      {latestPost && (
        <a
          href={`/posts/${latestPost.id}`}
          data-post-preview={`/posts/${latestPost.id}`}
          class="home-feature reveal-up"
          style="animation-delay: 120ms;"
        >
          <p class="eyebrow">Fresh Ink</p>
          <div class="home-feature-main">
            <time datetime={latestPost.data.pubDate.toISOString()}>{formatDate(latestPost.data.pubDate)}</time>
            <h2>{latestPost.data.title}</h2>
            <p>{latestPost.data.description ?? '从这篇文章开始逛逛我的博客'}</p>
          </div>
          <span class="home-feature-link">预览阅读 -></span>
        </a>
      )}

      <div class="home-topics reveal-up" style="animation-delay: 220ms;">
        <p class="eyebrow">What Lives Here</p>
        <h2>写作方向</h2>
        <p>喜欢分享生活呀，喜欢记录一些很酷的技术呀</p>
        <div>
          <span>Astro</span>
          <span>技术</span>
          <span>随笔</span>
          <span>学习笔记</span>
        </div>
      </div>
    </section>

    <section class="notes-section">
      <div class="notes-heading">
        <div>
          <p class="eyebrow">Latest Notes</p>
          <h2 class="section-title mt-3 text-2xl md:text-[1.75rem]">最近写了什么</h2>
        </div>
        <p>
          慢慢浏览知识库or我の日常~~
        </p>
      </div>
      {posts.length === 0 ? (
        <div class="empty-note">暂无文章，快去写一篇吧</div>
      ) : (
        <div class="notes-grid">
          {posts.map((post, index) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
              index={index}
              locked={post.data.locked}
            />
          ))}
        </div>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>
