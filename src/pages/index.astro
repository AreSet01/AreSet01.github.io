---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { formatDate, sortPostsByDate } from '../utils/date';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = sortPostsByDate(allPosts);
const latestPost = posts[0];
const totalTags = new Set(posts.flatMap(post => post.data.tags ?? [])).size;
const latestYear = latestPost ? new Date(latestPost.data.pubDate).getFullYear() : new Date().getFullYear();
---

<BaseLayout title="梦付千秋 - 日常记录与技术分享">
  <Header />
  <main class="container-wide flex-1 pb-12 pt-6 md:pb-16">
    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.45fr)_minmax(320px,0.85fr)]">
      <div class="panel reveal-up overflow-hidden rounded-[20px] px-7 py-9 md:px-11 md:py-12">
        <div class="hero-orb absolute right-7 top-7 hidden h-20 w-20 rounded-full md:block"></div>
        <p class="eyebrow">Digital Garden</p>
        <h1 class="section-title mt-5 max-w-3xl text-3xl md:text-4xl lg:text-[2.75rem]">
          发发牢骚，写写无关紧要小教程の小破网站
        </h1>
        <p class="mt-5 max-w-2xl text-[0.98rem] leading-relaxed text-[var(--muted)] md:text-base">
          也就随便分享一点小知识呀，一些行业看法呀，或是说些愤青言论等
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {latestPost && <a href={`/posts/${latestPost.id}`} class="btn-primary">阅读最新文章</a>}
          <a href="/archive" class="btn-secondary">浏览全部文章</a>
        </div>
        <div class="mt-9 grid gap-3 sm:grid-cols-3">
          <div class="stat-card">
            <p class="stat-label">文章数量</p>
            <p class="mt-2 text-2xl font-bold tracking-tight text-[var(--text-strong)]">{posts.length}</p>
          </div>
          <div class="stat-card">
            <p class="stat-label">标签数量</p>
            <p class="mt-2 text-2xl font-bold tracking-tight text-[var(--text-strong)]">{totalTags}</p>
          </div>
          <div class="stat-card">
            <p class="stat-label">最近更新</p>
            <p class="mt-2 text-2xl font-bold tracking-tight text-[var(--text-strong)]">{latestYear}</p>
          </div>
        </div>
      </div>

      <aside class="flex flex-col gap-6">
        {latestPost && (
          <div class="panel reveal-up overflow-hidden rounded-[16px] px-7 py-7 md:px-8 md:py-8" style="animation-delay: 120ms;">
            <p class="eyebrow">Fresh Ink</p>
            <h2 class="font-display mt-4 text-xl text-[var(--text-strong)]">最新更新</h2>
            <a
              href={`/posts/${latestPost.id}`}
              data-post-preview={`/posts/${latestPost.id}`}
              class="surface-link mt-4 px-5 py-4"
            >
              <p class="text-xs font-medium text-[var(--muted)]">
                {formatDate(latestPost.data.pubDate)}
              </p>
              <h3 class="font-display mt-2 text-[1.05rem] leading-snug text-[var(--text-strong)]">
                {latestPost.data.title}
              </h3>
              <p class="mt-2 text-[0.88rem] leading-relaxed text-[var(--muted)]">
                {latestPost.data.description ?? '从这篇文章开始逛逛我的博客'}
              </p>
            </a>
          </div>
        )}

        <div class="panel reveal-up rounded-[16px] px-7 py-7 md:px-8 md:py-8" style="animation-delay: 220ms;">
          <p class="eyebrow">What Lives Here</p>
          <h2 class="font-display mt-4 text-xl text-[var(--text-strong)]">写作方向</h2>
          <p class="mt-3 text-[0.9rem] leading-relaxed text-[var(--muted)]">
            喜欢分享生活呀，喜欢记录一些很酷的技术呀
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            <span class="tag-chip">Astro</span>
            <span class="tag-chip">技术</span>
            <span class="tag-chip">随笔</span>
            <span class="tag-chip">学习笔记</span>
          </div>
        </div>
      </aside>
    </section>

    <section class="mt-10">
      <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="eyebrow">Latest Notes</p>
          <h2 class="section-title mt-3 text-2xl md:text-[1.75rem]">最近写了什么</h2>
        </div>
        <p class="max-w-lg text-[0.9rem] leading-relaxed text-[var(--muted)]">
          慢慢浏览知识库or我の日常~~
        </p>
      </div>
      {posts.length === 0 ? (
        <div class="panel rounded-[16px] px-8 py-8 text-[var(--muted)]">暂无文章，快去写一篇吧</div>
      ) : (
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {posts.map((post, index) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
              index={index}
              locked={post.data.locked}
            />
          ))}
        </div>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>
