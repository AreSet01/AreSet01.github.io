---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于我 - 梦付千秋">
  <Header />
  <main class="container-wide flex-1 pb-12 pt-6 md:pb-16">
    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
      <div class="panel reveal-up rounded-[20px] px-7 py-9 md:px-11 md:py-11">
        <p class="eyebrow">About the Author</p>
        <h1 class="section-title mt-4 max-w-2xl text-2xl md:text-[2rem]">
          我是一个喜欢把技术学习写成长期作品的人。
        </h1>
        <div class="mt-5 space-y-3.5 text-[0.95rem] leading-relaxed text-[var(--muted)]">
          <p>你好，欢迎来到我的博客。这里记录日常，也记录那些让我兴奋的新技术和新想法。</p>
          <p>
            我喜欢编程，也喜欢把学到的知识慢慢整理成更容易回看的内容。对我来说，写作不是附属动作，
            而是学习过程本身。
          </p>
          <p>
            这个站点想做成一座小而稳定的数字花园，让教程、随笔和实验都能长期生长，而不是发完就沉下去。
          </p>
        </div>
        <div class="mt-7 grid gap-3 sm:grid-cols-3">
          <div class="stat-card">
            <p class="stat-label">写作主题</p>
            <p class="mt-2 text-[0.95rem] font-semibold text-[var(--text-strong)]">前端 / 日常 / 笔记</p>
          </div>
          <div class="stat-card">
            <p class="stat-label">当前栈</p>
            <p class="mt-2 text-[0.95rem] font-semibold text-[var(--text-strong)]">Astro + Tailwind</p>
          </div>
          <div class="stat-card">
            <p class="stat-label">写作习惯</p>
            <p class="mt-2 text-[0.95rem] font-semibold text-[var(--text-strong)]">边学边记，慢慢打磨</p>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <section class="panel reveal-up rounded-[16px] px-7 py-7 md:px-8 md:py-8" style="animation-delay: 120ms;">
          <p class="eyebrow">About the Site</p>
          <h2 class="font-display mt-4 text-xl text-[var(--text-strong)]">本站用什么搭的？</h2>
          <div class="mt-4 space-y-2.5 text-[0.9rem] leading-relaxed text-[var(--muted)]">
            <div class="surface-card px-4 py-3.5">
              <strong class="text-[var(--text-strong)]">Astro</strong>：用来构建快速、轻量的静态网站。
            </div>
            <div class="surface-card px-4 py-3.5">
              <strong class="text-[var(--text-strong)]">Tailwind CSS</strong>：负责高效率地整理页面样式。
            </div>
            <div class="surface-card px-4 py-3.5">
              <strong class="text-[var(--text-strong)]">Giscus</strong>：把评论系统放到 GitHub Discussions 里。
            </div>
          </div>
        </section>

        <section class="panel reveal-up rounded-[16px] px-7 py-7 md:px-8 md:py-8" style="animation-delay: 220ms;">
          <p class="eyebrow">Contact</p>
          <h2 class="font-display mt-4 text-xl text-[var(--text-strong)]">找到我</h2>
          <p class="mt-3 text-[0.9rem] leading-relaxed text-[var(--muted)]">
            这里放的是联系方式信息。GitHub 用户名你后面补上就行，邮箱我已经替你换好了。
          </p>
          <div class="mt-4 space-y-2.5">
            <a
              href="https://github.com/yourusername"
              class="surface-link px-4 py-3.5"
              target="_blank"
              rel="noopener"
            >
              <p class="stat-label">GitHub</p>
              <p class="mt-1.5 text-[0.95rem] font-semibold text-[var(--text-strong)]">@yourusername</p>
            </a>
            <div class="surface-card px-4 py-3.5">
              <p class="stat-label">Email</p>
              <p class="mt-1.5 text-[0.95rem] font-semibold text-[var(--text-strong)]">1909616051@qq.com</p>
            </div>
          </div>
        </section>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
