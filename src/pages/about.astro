---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于我 - My Blog">
  <Header />
  <main class="flex-1 max-w-3xl mx-auto w-full px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">关于我</h1>
    <div class="prose">
      <p>你好！欢迎来到我的博客。</p>
      <p>
        这里是我记录日常和分享技术的地方。我热爱编程，喜欢探索新技术，
        也享受把学到的知识整理分享出来的过程。
      </p>

      <h2>关于本站</h2>
      <p>本站使用以下技术构建：</p>
      <ul>
        <li><strong>Astro</strong> — 静态站点生成器</li>
        <li><strong>Tailwind CSS</strong> — 实用优先的 CSS 框架</li>
        <li><strong>Giscus</strong> — 基于 GitHub Discussions 的评论系统</li>
        <li><strong>Vercel</strong> — 部署托管平台</li>
      </ul>

      <h2>联系方式</h2>
      <ul>
        <li>GitHub: <a href="https://github.com/yourusername">@yourusername</a></li>
        <li>Email: your@email.com</li>
      </ul>
    </div>
  </main>
  <Footer />
</BaseLayout>
