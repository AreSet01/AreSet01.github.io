---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于我 - 梦付千秋">
  <Header />
  <main class="container-wide flex-1 pt-14 pb-16 md:pt-20">
    <section class="grid gap-16 lg:grid-cols-[minmax(0,1.25fr)_minmax(280px,0.75fr)] lg:gap-20">
      <div class="panel reveal-up">
        <p class="eyebrow">About the Author</p>
        <h1 class="section-title mt-6 max-w-2xl">
          美好的事物无时无刻都存在，<br />只是需要被发掘。
        </h1>
        <div
          class="mt-8 space-y-5 text-[1rem] leading-[1.85] text-[var(--muted-strong)] max-w-2xl"
          style="font-family: var(--font-serif);"
        >
          <p>你好，欢迎来到我的个人空间。这里记录日常，也记录那些让我兴奋的新技术和新想法。</p>
          <p>
            我喜欢编程，也喜欢把学到的知识慢慢整理成更容易回看的内容；喜欢记录自己的想法，并尝试去付诸行动实现它。
          </p>
          <p>
            这里是想要把自己的情绪、自己的想法、自己的学习过程记录下来的好地方。
          </p>
        </div>
        <div class="mt-12 grid gap-0 sm:grid-cols-3 border-t border-[var(--rule)]">
          <div class="stat-card sm:border-r sm:border-[var(--rule)] sm:pr-6">
            <p class="stat-label">写作主题</p>
            <p class="mt-3 font-display text-[1.05rem] text-[var(--text-strong)]">
              游戏 / 日常 / 笔记
            </p>
          </div>
          <div class="stat-card sm:border-r sm:border-[var(--rule)] sm:px-6">
            <p class="stat-label">当前栈</p>
            <p class="mt-3 font-display text-[1.05rem] text-[var(--text-strong)]">
              Astro + Tailwind
            </p>
          </div>
          <div class="stat-card sm:pl-6">
            <p class="stat-label">写作习惯</p>
            <p class="mt-3 font-display text-[1.05rem] text-[var(--text-strong)]">
              边学边记，慢慢打磨
            </p>
          </div>
        </div>
      </div>

      <aside class="space-y-12">
        <section class="reveal-up" style="animation-delay: 120ms;">
          <p class="eyebrow">About the Site</p>
          <h2 class="font-display mt-5 text-[1.65rem] text-[var(--text-strong)]">
            本站用什么搭的？
          </h2>
          <dl class="mt-6 border-t border-[var(--rule)]">
            <div class="flex items-baseline justify-between gap-4 border-b border-[var(--rule)] py-3.5">
              <dt class="font-display text-[1rem] text-[var(--text-strong)]">Astro</dt>
              <dd class="text-[0.86rem] text-[var(--muted)] text-right" style="font-family: var(--font-serif); font-style: italic;">
                快速、轻量的静态网站
              </dd>
            </div>
            <div class="flex items-baseline justify-between gap-4 border-b border-[var(--rule)] py-3.5">
              <dt class="font-display text-[1rem] text-[var(--text-strong)]">Tailwind</dt>
              <dd class="text-[0.86rem] text-[var(--muted)] text-right" style="font-family: var(--font-serif); font-style: italic;">
                高效整理样式
              </dd>
            </div>
            <div class="flex items-baseline justify-between gap-4 border-b border-[var(--rule)] py-3.5">
              <dt class="font-display text-[1rem] text-[var(--text-strong)]">Giscus</dt>
              <dd class="text-[0.86rem] text-[var(--muted)] text-right" style="font-family: var(--font-serif); font-style: italic;">
                GitHub Discussions 评论
              </dd>
            </div>
          </dl>
        </section>

        <section class="reveal-up" style="animation-delay: 220ms;">
          <p class="eyebrow">Contact</p>
          <h2 class="font-display mt-5 text-[1.65rem] text-[var(--text-strong)]">
            Call Me！
          </h2>
          <p
            class="mt-4 text-[0.94rem] leading-relaxed text-[var(--muted-strong)]"
            style="font-family: var(--font-serif); font-style: italic;"
          >
            如果你想联系我 —
          </p>
          <div class="mt-6 border-t border-[var(--rule)]">
            <a
              href="https://github.com/yourusername"
              class="surface-link flex items-baseline justify-between gap-4"
              target="_blank"
              rel="noopener"
            >
              <span class="stat-label">GitHub</span>
              <span class="font-display text-[1rem] text-[var(--text-strong)]">AreSet01 →</span>
            </a>
            <div class="flex items-baseline justify-between gap-4 border-t border-[var(--rule)] py-4">
              <span class="stat-label">Email</span>
              <span class="font-mono text-[0.84rem] text-[var(--text-strong)]">1909616051@qq.com</span>
            </div>
          </div>
        </section>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
