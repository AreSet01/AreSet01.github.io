          const scaleRatioX = sourceRect.width / Math.max(shellRect.width, 1);
          const scaleRatioY = sourceRect.height / Math.max(shellRect.height, 1);
          const sourceRadius = parseFloat(sourceStyle.borderTopLeftRadius) || 16;
          const startScaleX = Math.max(0.18, Math.min(0.86, scaleRatioX));
          const startScaleY = Math.max(0.14, Math.min(0.82, scaleRatioY));
          const pinchScaleX = Math.max(0.18, startScaleX * 0.66);
          const pinchScaleY = Math.min(1.04, Math.max(0.5, startScaleY * 1.18));
          const driftX = startX * -0.12;
          const driftY = startY * -0.08 - Math.max(6, sourceRadius * 0.18);

          imageViewerMotion = {
            startX,
            startY,
            startScaleX,
            startScaleY,
            pinchScaleX,
            pinchScaleY,
            driftX,
            driftY,
