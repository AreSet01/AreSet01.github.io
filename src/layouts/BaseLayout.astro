            imageViewerOverlayAnimation = null;
          };

          imageViewerOverlayAnimation.oncancel = () => {
            imageViewerOverlayAnimation = null;
          };

          imageViewerShellAnimation.onfinish = () => {
            applyImageViewerOpenStyles();
            releaseAnimation(imageViewerShellAnimation);
            imageViewerShellAnimation = null;
            imageViewerState = 'open';
          };

          imageViewerShellAnimation.oncancel = () => {
            imageViewerShellAnimation = null;
          };
        }

        function finishImageViewerClose(restoreFocusEl) {
          stopImageViewerAnimations();
          imageOverlay.classList.remove('is-open');
