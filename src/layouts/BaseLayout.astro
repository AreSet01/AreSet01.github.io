          const modalRect = modal.getBoundingClientRect();
          const sourceStyle = window.getComputedStyle(previewSourceEl);
          const startX = sourceRect.left + sourceRect.width / 2 - window.innerWidth / 2;
          const startY = sourceRect.top + sourceRect.height / 2 - window.innerHeight / 2;
          const scaleRatioX = sourceRect.width / Math.max(modalRect.width, 1);
          const scaleRatioY = sourceRect.height / Math.max(modalRect.height, 1);
          const sourceRadius = parseFloat(sourceStyle.borderTopLeftRadius) || 16;
          // True FLIP without arbitrary clamps
          const startScaleX = scaleRatioX;
          const startScaleY = scaleRatioY;
          const pinchScaleX = startScaleX * 0.8;
          const pinchScaleY = startScaleY * 1.05;
          const driftX = 0;
          const driftY = 0;
          const overshootScaleX = 1.018;
          const overshootScaleY = 0.988;

          previewMotion = {
            startX,
            startY,
            startScaleX,
            startScaleY,
            pinchScaleX,
            pinchScaleY,
            driftX,
            driftY,
            overshootScaleX,
            overshootScaleY,
          };
        }

        function applyPreviewStartStyles() {
          const { startX, startY, startScaleX, startScaleY } = previewMotion;
          overlay.style.opacity = '0';
          modal.style.transform = `translate3d(${startX}px, ${startY}px, 0) scale(${startScaleX}, ${startScaleY})`;
          modal.style.opacity = '0';
          modal.style.filter = 'blur(16px)';
        }

        function applyPreviewOpenStyles() {
          overlay.style.opacity = '1';
          modal.style.transform = 'translate3d(0, 0, 0) scale(1, 1)';
          modal.style.opacity = '1';
          modal.style.filter = 'blur(0)';
        }

        function clearPreviewInlineStyles() {
          overlay.style.removeProperty('opacity');
          modal.style.removeProperty('transform');
          modal.style.removeProperty('opacity');
          modal.style.removeProperty('filter');
        }

        function animatePreviewOpen() {
          stopPreviewAnimations();

          if (prefersReducedMotion) {
            applyPreviewOpenStyles();
            previewState = 'open';
            return;
          }

          const { startX, startY, startScaleX, startScaleY } = previewMotion;
          previewState = 'opening';

          if (window.gsap) {
             window.gsap.killTweensOf([overlay, modal]);
             window.gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.45, ease: "power2.out" });
             window.gsap.fromTo(modal, 
               { x: startX, y: startY, scaleX: startScaleX, scaleY: startScaleY, opacity: 0 },
               { x: 0, y: 0, scaleX: 1, scaleY: 1, opacity: 1, duration: 0.85, ease: "ink", onComplete: () => {
                 applyPreviewOpenStyles();
                 previewState = 'open';
               }}
             );
             window.gsap.fromTo(modal,
               { filter: 'blur(12px)' },
               { filter: 'blur(0px)', duration: 1.1, ease: "power2.out" }
             );
             return;
          }

          previewOverlayAnimation = overlay.animate(
            [{ opacity: 0 }, { opacity: 1 }],
            {
              duration: 450,
              easing: 'cubic-bezier(0.22, 0.82, 0.18, 1)',
              fill: 'both',
            }
          );

          previewModalAnimation = modal.animate(
            [
              {
                transform: `translate3d(${startX}px, ${startY}px, 0) scale(${startScaleX}, ${startScaleY})`,
                opacity: 0,
                filter: 'blur(16px)',
              },
              {
                transform: `translate3d(${startX * 0.3}px, ${startY * 0.3}px, 0) scale(${startScaleX + (1 - startScaleX) * 0.5}, ${startScaleY + (1 - startScaleY) * 0.5})`,
                opacity: 0.8,
                filter: 'blur(4.5px)',
                offset: 0.4,
              },
              {
                transform: 'translate3d(0, 0, 0) scale(1, 1)',
                opacity: 1,
                filter: 'blur(0)',
              },
            ],
            {
              duration: 850,
              easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
              fill: 'both',
            }
          );

          previewOverlayAnimation.onfinish = () => {
            overlay.style.opacity = '1';
            releaseAnimation(previewOverlayAnimation);
            previewOverlayAnimation = null;
          };

          previewOverlayAnimation.oncancel = () => {
            previewOverlayAnimation = null;
          };

          previewModalAnimation.onfinish = () => {
            applyPreviewOpenStyles();
            releaseAnimation(previewModalAnimation);
            previewModalAnimation = null;
            previewState = 'open';
          };

          previewModalAnimation.oncancel = () => {
            previewModalAnimation = null;
          };
        }

        function openPreview(url, sourceEl) {
          cancelAnimationFrame(previewOpenFrame);
          stopPreviewAnimations();
          currentUrl = url;
          setPreviewMotion(sourceEl);
          readFullBtn.href = url;
          titleEl.textContent = '加载中...';
          bodyEl.innerHTML = `
            <div class="preview-loading">
              <div class="preview-spinner"></div>
              <span>正在加载预览...</span>
            </div>
          `;
          bodyEl.scrollTop = 0;
          syncScrollbarOffset();
          document.body.classList.add('preview-lock');
          document.body.classList.add('preview-active');
          if (window.lenis) window.lenis.stop();
          overlay.classList.add('is-open');
          applyPreviewStartStyles();

          previewOpenFrame = requestAnimationFrame(() => {
            document.body.classList.add('preview-open');
            animatePreviewOpen();
            previewOpenFrame = 0;
          });

          window.setTimeout(() => {
            if (overlay.classList.contains('is-open')) closeBtn.focus();
          }, 180);

          if (previewCache.has(url)) {
            renderPreview(previewCache.get(url));
            return;
          }

          fetch(url)
            .then((response) => {
              if (!response.ok) throw new Error(`HTTP ${response.status}`);
              return response.text();
            })
            .then((html) => {
              const parsed = parsePostHtml(html);
              previewCache.set(url, parsed);
              if (currentUrl === url) renderPreview(parsed);
            })
            .catch(() => {
              if (currentUrl !== url) return;

              titleEl.textContent = '加载失败';
              bodyEl.innerHTML = `
                <div class="preview-error">
                  <div style="font-size: 2rem; opacity: 0.5;">!</div>
                  <p style="font-size: 0.95rem; line-height: 1.5;">
                    无法加载文章预览。<br>
                    <a href="${url}" style="color: var(--accent-strong); text-decoration: underline;">改为阅读全文</a>
                  </p>
                </div>
              `;
            });
        }

        function parsePostHtml(html) {
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const titleNode = doc.querySelector('.section-title');
          const title = titleNode ? titleNode.textContent.trim() : '';
          if (doc.querySelector('[data-locked-post="true"]')) {
            return {
              title,
              content: '<p>这篇文章上锁啦！密码的话，不知道哇~</p>',
            };
          }
          const proseEl = doc.querySelector('.prose');
          const content = proseEl ? proseEl.innerHTML : '<p>无法解析文章内容。</p>';
          return { title, content };
        }

        function renderPreview({ title, content }) {
          titleEl.textContent = title || '文章预览';
          bodyEl.innerHTML = `<div class="prose">${content}</div>`;
        }

        function finishPreviewClose(restoreFocusEl) {
          stopPreviewAnimations();
          overlay.classList.remove('is-open');
          document.body.classList.remove('preview-open');
          document.body.classList.remove('preview-lock');
          document.body.classList.remove('preview-active');
          syncScrollbarOffset();
          clearPreviewInlineStyles();
          resetPreviewMotion();
          currentUrl = '';
          previewState = 'closed';
          previewSourceEl = null;

          if (window.lenis) window.lenis.start();
          if (restoreFocusEl instanceof HTMLElement && restoreFocusEl.isConnected) {
            restoreFocusEl.focus({ preventScroll: true });
          }
        }

        function closePreview() {
          if (!overlay.classList.contains('is-open') || previewState === 'closing') return;

          const restoreFocusEl = previewSourceEl;
          cancelAnimationFrame(previewOpenFrame);
          stopPreviewAnimations();

          if (prefersReducedMotion) {
            finishPreviewClose(restoreFocusEl);
            return;
          }

          previewState = 'closing';
          document.body.classList.remove('preview-open');
          document.body.classList.remove('preview-active');
          applyPreviewOpenStyles();

          const { startX, startY, startScaleX, startScaleY } = previewMotion;

          if (window.gsap) {
             window.gsap.killTweensOf([overlay, modal]);
             window.gsap.to(overlay, { opacity: 0, duration: 0.4, ease: "power2.inOut" });
             window.gsap.to(modal, { 
               x: startX, y: startY, scaleX: startScaleX, scaleY: startScaleY, opacity: 0, filter: 'blur(12px)', 
               duration: 0.55, ease: "power3.inOut", onComplete: () => {
                 finishPreviewClose(restoreFocusEl);
               }
             });
             return;
          }

          previewOverlayAnimation = overlay.animate(
            [{ opacity: 1 }, { opacity: 0 }],
            {
              duration: 400,
              easing: 'cubic-bezier(0.36, 0, 0.4, 1)',
              fill: 'both',
            }
          );

          previewModalAnimation = modal.animate(
            [
              {
                transform: 'translate3d(0, 0, 0) scale(1, 1)',
                opacity: 1,
                filter: 'blur(0)',
              },
              {
                transform: `translate3d(${startX}px, ${startY}px, 0) scale(${startScaleX}, ${startScaleY})`,
                opacity: 0,
                filter: 'blur(14px)',
              },
            ],
            {
              duration: 550,
              easing: 'cubic-bezier(0.4, 0, 0.5, 1)',
              fill: 'both',
            }
          );

          previewOverlayAnimation.onfinish = () => {
            overlay.style.opacity = '0';
            releaseAnimation(previewOverlayAnimation);
            previewOverlayAnimation = null;
          };

          previewOverlayAnimation.oncancel = () => {
            previewOverlayAnimation = null;
          };

          previewModalAnimation.onfinish = () => {
            finishPreviewClose(restoreFocusEl);
          };

          previewModalAnimation.oncancel = () => {
            previewModalAnimation = null;
          };
        }

        document.addEventListener('click', (event) => {
          if (event.ctrlKey || event.metaKey || event.shiftKey || event.button !== 0) return;

          const link = event.target.closest('[data-post-preview]');
          if (!link) return;

          const previewUrl = link.getAttribute('data-post-preview');
          if (!previewUrl) return;

          event.preventDefault();
          previewClickActive = true;
          openPreview(previewUrl, link);
        }, { capture: true, signal });

        overlay.addEventListener('click', (event) => {
          if (event.target === overlay) closePreview();
        }, { signal });

        closeBtn.addEventListener('click', (event) => {
          event.stopPropagation();
          closePreview();
        }, { signal });

        document.addEventListener('click', (event) => {
          if (event.ctrlKey || event.metaKey || event.shiftKey || event.button !== 0) return;

          const target = event.target.closest('.prose img');
          if (!(target instanceof HTMLImageElement)) return;

          event.preventDefault();
          event.stopPropagation();
          openImageViewer(target);
        }, { capture: true, signal });

        imageOverlay.addEventListener('click', (event) => {
          if (event.target === imageOverlay) closeImageViewer();
        }, { signal });

        imageViewerCloseBtn.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          closeImageViewer();
        }, { signal });

        if (searchReady) {
          document.querySelectorAll('[data-search-trigger]').forEach((trigger) => {
            trigger.addEventListener('click', (event) => {
              event.preventDefault();
              openSearch(trigger);
            }, { signal });
          });

          searchOverlay.addEventListener('click', (event) => {
            if (event.target === searchOverlay) closeSearch();
          }, { signal });

          searchCloseBtn.addEventListener('click', (event) => {
            event.preventDefault();
            closeSearch();
          }, { signal });

          searchInput.addEventListener('input', () => {
            updateSearchResults();
          }, { signal });

          searchInput.addEventListener('keydown', (event) => {
            if (event.key === 'ArrowDown') {
              event.preventDefault();
              setActiveSearchResult(searchActiveIndex + 1);
              return;
            }

            if (event.key === 'ArrowUp') {
              event.preventDefault();
              setActiveSearchResult(searchActiveIndex - 1);
              return;
            }

            if (event.key === 'Enter' && searchActiveIndex >= 0 && searchResults[searchActiveIndex]) {
              event.preventDefault();
              window.location.assign(searchResults[searchActiveIndex].href);
              return;
            }

            if (event.key === 'Escape') {
              event.preventDefault();
              closeSearch();
            }
          }, { signal });

          searchResultsEl.addEventListener('mousemove', (event) => {
            const target = event.target.closest('[data-search-result]');
            if (!target) return;
            setActiveSearchResult(Number(target.getAttribute('data-index')));
          }, { signal });

          searchResultsEl.addEventListener('click', (event) => {
            const target = event.target.closest('[data-search-result]');
            if (!target) return;
            closeSearch(false);
          }, { signal });
        }

        document.addEventListener('keydown', (event) => {
          const isSearchShortcut =
            event.key.toLowerCase() === 'k' && (event.ctrlKey || event.metaKey);

          if (isSearchShortcut && !event.shiftKey && !event.altKey) {
            event.preventDefault();
            if (searchOverlay?.classList.contains('is-open')) {
              closeSearch();
            } else {
              openSearch(document.querySelector('[data-search-trigger]'));
            }
            return;
          }

          if (event.key === 'Escape' && searchOverlay?.classList.contains('is-open')) {
            closeSearch();
            return;
          }

          if (event.key === 'Escape' && imageOverlay.classList.contains('is-open')) {
            closeImageViewer();
            return;
          }

          if (event.key === 'Escape' && overlay.classList.contains('is-open')) closePreview();
        }, { signal });
        window[cleanupKey] = () => {
          if (isDisposed) return;
          isDisposed = true;
          controller.abort();
          stopImageViewerAnimations();
          restoreSourceImageHidden(imageViewerSourceEl);
          revealObserver?.disconnect();
          revealObserver = null;
          cancelAnimationFrame(ambientFrame);
          cancelAnimationFrame(previewOpenFrame);
          clearSearchCloseTimer();
          stopPreviewAnimations();
          overlay.remove();
          imageOverlay.remove();
          canvas.remove();
          document.body.classList.remove('search-lock', 'search-open', 'preview-lock', 'preview-active', 'preview-open', 'image-view-open');
          document.documentElement.style.setProperty('--scrollbar-offset', '0px');
        };
      }

      window[initKey] = initSiteUi;
      initSiteUi();

      if (!window[listenerKey]) {
        document.addEventListener('astro:page-load', () => {
          const init = window[initKey];
          if (typeof init === 'function') init();
        });
        window[listenerKey] = true;
      }

        /* ========== 5. 鼠标光标追踪光晕 ========== */
        // 已移至独立 script 标签
      })();
    </script>
    <script is:inline>
      (() => {
        const cleanupKey = '__areSetCursorGlowCleanup__';
        const initKey = '__areSetCursorGlowInit__';
        const listenerKey = '__areSetCursorGlowPageLoadBound__';
        const stateKey = '__areSetCursorGlowState__';

        function initCursorGlow() {
          const lightPalette = ['26, 24, 20', '168, 57, 43'];
          const darkPalette  = ['235, 226, 207', '212, 74, 60'];

          function paletteForTheme() {
            return document.documentElement.getAttribute('data-theme') === 'dark'
              ? darkPalette
              : lightPalette;
          }

          const state = window[stateKey] || { colorIndex: 0, glowColors: paletteForTheme() };
          state.glowColors = paletteForTheme();
          window[stateKey] = state;

          if (state.glow && state.glow.isConnected) {
            return;
          }

          const previousCleanup = window[cleanupKey];
          if (typeof previousCleanup === 'function') previousCleanup();

          document.querySelectorAll('.cursor-glow').forEach((node) => node.remove());

          if (!window.matchMedia('(pointer: fine)').matches) {
            window[cleanupKey] = null;
            return;
          }

          const controller = new AbortController();
          const { signal } = controller;
          const glow = document.createElement('div');
          glow.className = 'cursor-glow';
          document.body.appendChild(glow);

          let glowFrame = 0;
          let glowX = 0;
          let glowY = 0;
          let targetX = 0;
          let targetY = 0;
          let isVisible = false;
          let isHovering = false;
          let cachedOffset = 12;

          function applyGlowColor(index) {
            const palette = state.glowColors;
            const color = palette[index] || palette[0];
            glow.style.setProperty('--cursor-rgb', color);
          }

          applyGlowColor(state.colorIndex || 0);

          window.addEventListener('theme-change', () => {
            state.glowColors = paletteForTheme();
            applyGlowColor(state.colorIndex || 0);
          }, { signal });

          function updateGlow() {
            const followStrength = isHovering ? 0.48 : 0.62;
            glowX += (targetX - glowX) * followStrength;
            glowY += (targetY - glowY) * followStrength;
            glow.style.transform = `translate3d(${glowX - cachedOffset}px, ${glowY - cachedOffset}px, 0)`;
            glowFrame = requestAnimationFrame(updateGlow);
          }

          glowFrame = requestAnimationFrame(updateGlow);

          document.addEventListener('pointermove', (event) => {
            targetX = event.clientX;
            targetY = event.clientY;
            if (!isVisible) {
              glowX = targetX;
              glowY = targetY;
              isVisible = true;
              glow.classList.add('is-visible');
            }
          }, { signal });

          document.addEventListener('pointerleave', () => {
            isVisible = false;
            isHovering = false;
            glow.classList.remove('is-visible', 'is-hovering');
          }, { signal });

          function createFirework(x, y, color) {
            const particleCount = 16 + Math.floor(Math.random() * 12);
            for (let i = 0; i < particleCount; i++) {
              const particle = document.createElement('div');
              const angle = Math.random() * 2 * Math.PI;
              const velocity = 40 + Math.random() * 80;
              const tx = Math.cos(angle) * velocity;
              const ty = Math.sin(angle) * velocity;
              const size = 3 + Math.random() * 5;
              const duration = 500 + Math.random() * 500;

              particle.style.cssText = `
                position: fixed;
                left: ${x}px;
                top: ${y}px;
                width: ${size}px;
                height: ${size}px;
                background: rgb(${color});
                border-radius: 50%;
                pointer-events: none;
                z-index: 9999;
                transform: translate(-50%, -50%);
                box-shadow: 0 0 8px rgba(${color}, 0.9), 0 0 16px rgba(${color}, 0.4);
                will-change: transform, opacity;
              `;
              document.body.appendChild(particle);

              particle.animate([
                { transform: 'translate(-50%, -50%) scale(1)', opacity: 1 },
                { transform: `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px)) scale(0)`, opacity: 0 }
              ], {
                duration: duration,
                easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
                fill: 'forwards'
              });

              setTimeout(() => particle.remove(), duration + 50);
            }
          }

          document.addEventListener('pointerdown', (event) => {
            if (event.button !== 0) return;
            state.colorIndex = ((state.colorIndex || 0) + 1) % state.glowColors.length;
            applyGlowColor(state.colorIndex);

            const color = state.glowColors[state.colorIndex] || state.glowColors[0];
            createFirework(event.clientX, event.clientY, color);
          }, { signal });

          document.addEventListener('mouseover', (event) => {
            const target = event.target instanceof Element ? event.target : null;
            const interactive = target?.closest('a, button, .tag-chip, .nav-link, .btn-primary, .btn-secondary, .stat-card, .timeline-link, .prose img, .image-viewer-close, [data-post-preview], [data-search-trigger], [data-search-result]');
            if (interactive) {
              isHovering = true;
              cachedOffset = 15;
              glow.classList.add('is-hovering');
            } else {
              isHovering = false;
              cachedOffset = 12;
              glow.classList.remove('is-hovering');
            }
          }, { signal });

          window[cleanupKey] = () => {
            controller.abort();
            cancelAnimationFrame(glowFrame);
            state.glow = null;
            glow.remove();
          };

          state.glow = glow;
        }

        window[initKey] = initCursorGlow;
        initCursorGlow();

        if (!window[listenerKey]) {
          document.addEventListener('astro:page-load', () => {
            const init = window[initKey];
            if (typeof init === 'function') init();
          });
          window[listenerKey] = true;
        }
      })();
    </script>
    <script is:inline>
      /* ========== 深色模式切换 ========== */
      (function() {
        var toggleKey = '__areSetThemeToggleBound__';
        if (window[toggleKey]) return;

        document.addEventListener('click', function(e) {
          var btn = e.target.closest('[data-theme-toggle]');
          if (!btn) return;

          var current = document.documentElement.getAttribute('data-theme') || 'light';
          var next = current === 'dark' ? 'light' : 'dark';

          try {
            localStorage.setItem('theme', next);
          } catch (error) {}

          if (typeof window.__transitionTheme === 'function') {
            window.__transitionTheme(next, btn);
          } else if (typeof window.__applyTheme === 'function') {
            window.__applyTheme(next);
          } else {
            document.documentElement.setAttribute('data-theme', next);
          }
        });

        window[toggleKey] = true;
      })();
    </script>
    <script is:inline>
      /* ========== 阅读进度条 ========== */
      (function initProgress() {
        function setup() {
          var old = document.querySelector('.reading-progress');
          if (old) old.remove();

          var prose = document.querySelector('.prose');
          if (!prose) return;

          var bar = document.createElement('div');
          bar.className = 'reading-progress';
          document.body.appendChild(bar);

          function update() {
            var rect = prose.getBoundingClientRect();
            var top = -rect.top;
            var total = rect.height - window.innerHeight;
            if (total <= 0) { bar.style.width = '100%'; return; }
            var pct = Math.min(100, Math.max(0, (top / total) * 100));
            bar.style.width = pct + '%';
            if (pct >= 99.5) {
              bar.classList.add('is-hidden');
            } else {
              bar.classList.remove('is-hidden');
            }
          }

          window.addEventListener('scroll', update, { passive: true });
          window.addEventListener('resize', update, { passive: true });
          update();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setup);
        } else {
          setup();
        }
        document.addEventListener('astro:page-load', setup);
      })();
    </script>
  </body>
</html>
