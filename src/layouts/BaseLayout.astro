---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

const searchIndexPath = `${import.meta.env.BASE_URL ?? '/'}search-index.json`;

interface Props {
  title: string;
  description?: string;
}

const { title, description = '梦付千秋 - 日常记录与技术分享' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4efe3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <script is:inline>
      (function(){
        var runtimeKey = '__areSetThemeRuntimeBound__';
        var themeTransitionTimer = 0;

        function getStoredTheme() {
          try {
            var stored = localStorage.getItem('theme');
            return stored === 'dark' || stored === 'light' ? stored : null;
          } catch (error) {
            return null;
          }
        }

        function resolveTheme(explicitTheme) {
          if (explicitTheme === 'dark' || explicitTheme === 'light') return explicitTheme;
          var storedTheme = getStoredTheme();
          if (storedTheme) return storedTheme;
          return window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light';
        }

        function syncThemeColor(theme) {
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0f1729' : '#f4efe3');
          document.documentElement.style.colorScheme = theme;
        }

        function syncGiscusTheme(theme) {
          var giscusTheme = theme === 'dark' ? 'dark_dimmed' : 'light';
          var script = document.querySelector('script[src="https://giscus.app/client.js"]');
          if (script) script.setAttribute('data-theme', giscusTheme);

          var frame = document.querySelector('iframe.giscus-frame');
          if (frame && frame.contentWindow) {
            frame.contentWindow.postMessage(
              { giscus: { setConfig: { theme: giscusTheme } } },
              'https://giscus.app'
            );
          }
        }

        function markThemeSwitching() {
          document.documentElement.classList.add('theme-switching');
          window.clearTimeout(themeTransitionTimer);
          themeTransitionTimer = window.setTimeout(function() {
            document.documentElement.classList.remove('theme-switching');
          }, 860);
        }

        function applyTheme(explicitTheme) {
          var nextTheme = resolveTheme(explicitTheme);
          document.documentElement.setAttribute('data-theme', nextTheme);
          syncThemeColor(nextTheme);

          requestAnimationFrame(function() { syncGiscusTheme(nextTheme); });
          window.setTimeout(function() { syncGiscusTheme(nextTheme); }, 180);
          window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: nextTheme } }));
          return nextTheme;
        }

        function transitionTheme(nextTheme, sourceEl) {
          var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          if (
            prefersReducedMotion ||
            !sourceEl ||
            typeof document.startViewTransition !== 'function'
          ) {
            markThemeSwitching();
            applyTheme(nextTheme);
            return;
          }

          var rect = sourceEl.getBoundingClientRect();
          var x = rect.left + rect.width / 2;
          var y = rect.top + rect.height / 2;
          var endRadius = Math.hypot(
            Math.max(x, window.innerWidth - x),
            Math.max(y, window.innerHeight - y)
          );

          var transition = document.startViewTransition(function() {
            markThemeSwitching();
            applyTheme(nextTheme);
          });

          transition.ready
            .then(function() {
              document.documentElement.animate(
                {
                  clipPath: [
                    'circle(18px at ' + x + 'px ' + y + 'px)',
                    'circle(' + endRadius + 'px at ' + x + 'px ' + y + 'px)',
                  ],
                  opacity: [0.72, 1],
                  filter: ['brightness(0.96) saturate(0.96)', 'brightness(1) saturate(1)'],
                },
                {
                  duration: 760,
                  easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
                  pseudoElement: '::view-transition-new(root)',
                }
              );
            })
            .catch(function() {});
        }

        window.__getPreferredTheme = resolveTheme;
        window.__applyTheme = applyTheme;
        window.__transitionTheme = transitionTheme;
        applyTheme();

        if (window[runtimeKey]) return;

        document.addEventListener('astro:after-swap', function() {
          applyTheme();
        });

        document.addEventListener('astro:page-load', function() {
          applyTheme();
        });

        var media = window.matchMedia('(prefers-color-scheme:dark)');
        if (media && typeof media.addEventListener === 'function') {
          media.addEventListener('change', function() {
            if (getStoredTheme()) return;
            applyTheme();
          });
        }

        window[runtimeKey] = true;
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
    <div class="search-overlay" id="site-search" aria-hidden="true">
      <div class="search-modal" role="dialog" aria-modal="true" aria-labelledby="search-title">
        <div class="search-panel">
          <div class="search-header">
            <div class="search-heading">
              <p class="eyebrow">Command Palette</p>
              <h2 class="search-title" id="search-title">搜索文章</h2>
            </div>
            <button class="search-close-btn" type="button" aria-label="关闭搜索">
              Esc
            </button>
          </div>
          <label class="search-input-shell" for="site-search-input">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.6"></circle>
              <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
            </svg>
            <input
              id="site-search-input"
              class="search-input"
              type="search"
              placeholder="搜索标题、标签或摘要..."
              autocomplete="off"
              spellcheck="false"
            />
          </label>
          <div class="search-status" data-search-status>输入关键词，或直接浏览最近更新。</div>
          <div class="search-results" data-search-results></div>
          <div class="search-footer">
            <div class="search-footer-item">
              <span class="search-kbd">↑</span>
              <span class="search-kbd">↓</span>
              <span>切换结果</span>
            </div>
            <div class="search-footer-item">
              <span class="search-kbd">Enter</span>
              <span>打开文章</span>
            </div>
            <div class="search-footer-item">
              <span class="search-kbd">Esc</span>
              <span>关闭面板</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script define:vars={{ searchIndexPath }}>
      (() => {
        const cleanupKey = '__areSetSiteUiCleanup__';
        const initKey = '__areSetSiteUiInit__';
        const listenerKey = '__areSetSiteUiPageLoadBound__';

        function initSiteUi() {
          const previousCleanup = window[cleanupKey];
          if (typeof previousCleanup === 'function') previousCleanup();

          const controller = new AbortController();
          const { signal } = controller;
          let isDisposed = false;
          let ambientFrame = 0;
          let revealObserver = null;

          document.querySelectorAll('canvas[data-ambient-canvas]').forEach((node) => node.remove());
          document.querySelectorAll('.preview-overlay[data-generated-preview]').forEach((node) => node.remove());
          document.querySelectorAll('.image-viewer-overlay[data-generated-image-viewer]').forEach((node) => node.remove());
          document.body.classList.remove('search-lock', 'search-open', 'preview-lock', 'preview-active', 'preview-open', 'image-view-open');
          document.documentElement.style.setProperty('--scrollbar-offset', '0px');

        const sparkleColors = [
          '#7cb3f0', '#5a9ee6', '#a8d0f8',
          '#f0a8c8', '#e88ab0', '#f8c8dc',
          '#c8a0e0', '#b8d8f8', '#f0b8d8',
          '#93c5fd', '#f9a8d4', '#c4b5fd',
        ];

        function sparkle(x, y, count) {
          const frag = document.createDocumentFragment();
          for (let i = 0; i < count; i += 1) {
            const el = document.createElement('div');
            const size = Math.random() * 6 + 3;
            const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.6;
            const distance = Math.random() * 100 + 40;
            const color = sparkleColors[Math.floor(Math.random() * sparkleColors.length)];
            const delay = Math.random() * 80;
            const shape = Math.random() > 0.5 ? '50%' : `${2 + Math.random() * 3}px`;

            Object.assign(el.style, {
              position: 'fixed',
              left: `${x - size / 2}px`,
              top: `${y - size / 2}px`,
              width: `${size}px`,
              height: `${size}px`,
              borderRadius: shape,
              background: color,
              pointerEvents: 'none',
              zIndex: '9999',
              boxShadow: `0 0 ${size + 4}px ${color}`,
              opacity: '1',
              transition: 'none',
            });

            frag.appendChild(el);

            window.setTimeout(() => {
              requestAnimationFrame(() => {
                const gravity = 20 + Math.random() * 30;
                Object.assign(el.style, {
                  transition: 'transform 1.2s cubic-bezier(0.22, 1, 0.36, 1), opacity 1.2s ease-out',
                  transform: `translate(${Math.cos(angle) * distance}px, ${Math.sin(angle) * distance + gravity}px) scale(0)`,
                  opacity: '0',
                });
              });
            }, delay);

            window.setTimeout(() => el.remove(), 1400);
          }

          document.body.appendChild(frag);
        }

        function initRevealUp() {
          const revealNodes = Array.from(document.querySelectorAll('.reveal-up'));
          if (!revealNodes.length) return;
          let revealDirection = 1;
          let revealLastScrollY = window.scrollY;
          const revealThreshold = 0.16;

          window.addEventListener('scroll', () => {
            const nextScrollY = window.scrollY;
            const delta = nextScrollY - revealLastScrollY;
            if (Math.abs(delta) > 1) {
              revealDirection = delta > 0 ? 1 : -1;
            }
            revealLastScrollY = nextScrollY;
          }, { passive: true, signal });

          if (!('IntersectionObserver' in window)) {
            revealNodes.forEach((node) => {
              node.classList.add('reveal-from-bottom', 'is-revealed');
            });
            return;
          }

          revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              const target = entry.target;
              const isVisible = target.dataset.revealVisible === 'true';

              if (!entry.isIntersecting) {
                if (!isVisible) return;
                target.dataset.revealVisible = 'false';
                target.classList.remove('is-revealed', 'reveal-from-bottom', 'reveal-from-top');
                return;
              }

              if (isVisible || entry.intersectionRatio < revealThreshold) {
                return;
              }

              const directionClass = revealDirection >= 0 ? 'reveal-from-bottom' : 'reveal-from-top';
              target.classList.remove('is-revealed', 'reveal-from-bottom', 'reveal-from-top');
              target.classList.add(directionClass);
              void target.offsetWidth;
              target.classList.add('is-revealed');
              target.dataset.revealVisible = 'true';
            });
          }, {
            threshold: [0, revealThreshold],
            rootMargin: '10% 0px 10% 0px',
          });

          revealNodes.forEach((node) => {
            revealObserver.observe(node);
          });
        }

        initRevealUp();

        document.addEventListener('click', (event) => {
          const isPreviewOpen =
            previewClickActive ||
            event.target.closest('[data-post-preview]');
          const isSearchInteraction = event.target.closest(
            '[data-search-trigger], .search-close-btn, [data-search-result]'
          );
          const isImageInteraction = event.target.closest(
            '.prose img, .image-viewer-overlay, .image-viewer-close'
          );

          if (isPreviewOpen || isSearchInteraction || isImageInteraction) return;
          sparkle(event.clientX, event.clientY, 18);
        }, { signal });

        let previewClickActive = false;
        document.addEventListener('click', (event) => {
          if (previewClickActive) {
            previewClickActive = false;
            return;
          }

          if (event.target.closest('.preview-overlay, .preview-close-btn, .preview-read-full, .search-overlay, .search-close-btn')) {
            return;
          }

          const el = event.target.closest('a, button, .tag-chip, .nav-link, .timeline-link, .btn-primary, .btn-secondary, .stat-card');
          if (!el) return;

          el.classList.remove('pop-active');
          void el.offsetWidth;
          el.classList.add('pop-active');
          el.addEventListener('animationend', () => el.classList.remove('pop-active'), { once: true, signal });
        }, { signal });

        const canvas = document.createElement('canvas');
        canvas.dataset.ambientCanvas = 'true';
        Object.assign(canvas.style, {
          position: 'fixed',
          inset: '0',
          zIndex: '0',
          pointerEvents: 'none',
          opacity: '0.55',
        });
        document.body.prepend(canvas);

        const ctx = canvas.getContext('2d');
        let viewportWidth = 0;
        let viewportHeight = 0;

        function resizeCanvas() {
          viewportWidth = canvas.width = window.innerWidth;
          viewportHeight = canvas.height = window.innerHeight;
        }

        resizeCanvas();
        window.addEventListener('resize', resizeCanvas, { signal });

        if (ctx) {
          const dots = [];
          const dotCount = 32;
          const ambientColors = [
            'rgba(147,197,253,0.5)',
            'rgba(196,181,253,0.45)',
            'rgba(249,168,212,0.45)',
            'rgba(165,220,252,0.4)',
            'rgba(253,186,210,0.4)',
          ];

          for (let i = 0; i < dotCount; i += 1) {
            dots.push({
              x: Math.random() * viewportWidth,
              y: Math.random() * viewportHeight,
              r: Math.random() * 3 + 1.5,
              dx: (Math.random() - 0.5) * 0.3,
              dy: (Math.random() - 0.5) * 0.2 - 0.1,
              color: ambientColors[Math.floor(Math.random() * ambientColors.length)],
              phase: Math.random() * Math.PI * 2,
            });
          }

          function drawDots(time) {
            ctx.clearRect(0, 0, viewportWidth, viewportHeight);

            for (const dot of dots) {
              dot.x += dot.dx + Math.sin(time * 0.0005 + dot.phase) * 0.15;
              dot.y += dot.dy + Math.cos(time * 0.0004 + dot.phase) * 0.1;

              if (dot.x < -10) dot.x = viewportWidth + 10;
              if (dot.x > viewportWidth + 10) dot.x = -10;
              if (dot.y < -10) dot.y = viewportHeight + 10;
              if (dot.y > viewportHeight + 10) dot.y = -10;

              const pulse = 0.7 + Math.sin(time * 0.001 + dot.phase) * 0.3;

              ctx.beginPath();
              ctx.arc(dot.x, dot.y, dot.r * pulse, 0, Math.PI * 2);
              ctx.fillStyle = dot.color;
              ctx.fill();

              ctx.beginPath();
              ctx.arc(dot.x, dot.y, dot.r * pulse * 2.5, 0, Math.PI * 2);
              const gradient = ctx.createRadialGradient(dot.x, dot.y, 0, dot.x, dot.y, dot.r * pulse * 2.5);
              gradient.addColorStop(0, dot.color);
              gradient.addColorStop(1, 'transparent');
              ctx.fillStyle = gradient;
              ctx.fill();
            }

            ambientFrame = requestAnimationFrame(drawDots);
          }

          ambientFrame = requestAnimationFrame(drawDots);
        }

        const overlay = document.createElement('div');
        overlay.className = 'preview-overlay';
        overlay.dataset.generatedPreview = 'true';
        overlay.innerHTML = `
          <div class="preview-modal" role="dialog" aria-modal="true" aria-labelledby="preview-title">
            <div class="preview-modal-header">
              <h2 class="preview-modal-title" id="preview-title"></h2>
              <button class="preview-close-btn" aria-label="关闭预览" type="button">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="3" y1="3" x2="13" y2="13"></line>
                  <line x1="13" y1="3" x2="3" y2="13"></line>
                </svg>
              </button>
            </div>
            <div class="preview-modal-body"></div>
            <div class="preview-modal-footer">
              <a class="btn-primary preview-read-full" href="#">阅读全文 -></a>
            </div>
          </div>
        `;
        document.body.appendChild(overlay);

        const modal = overlay.querySelector('.preview-modal');
        const titleEl = overlay.querySelector('.preview-modal-title');
        const bodyEl = overlay.querySelector('.preview-modal-body');
        const closeBtn = overlay.querySelector('.preview-close-btn');
        const readFullBtn = overlay.querySelector('.preview-read-full');
        const imageOverlay = document.createElement('div');
        imageOverlay.className = 'image-viewer-overlay';
        imageOverlay.dataset.generatedImageViewer = 'true';
        imageOverlay.innerHTML = `
          <div class="image-viewer-shell" role="dialog" aria-modal="true" aria-labelledby="image-viewer-caption">
            <button class="image-viewer-close" aria-label="关闭图片预览" type="button">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="3" y1="3" x2="13" y2="13"></line>
                <line x1="13" y1="3" x2="3" y2="13"></line>
              </svg>
            </button>
            <div class="image-viewer-stage">
              <img class="image-viewer-media" alt="" />
              <p class="image-viewer-caption" id="image-viewer-caption" hidden></p>
            </div>
          </div>
        `;
        document.body.appendChild(imageOverlay);
        const imageViewerCloseBtn = imageOverlay.querySelector('.image-viewer-close');
        const imageViewerShell = imageOverlay.querySelector('.image-viewer-shell');
        const imageViewerMedia = imageOverlay.querySelector('.image-viewer-media');
        const imageViewerCaption = imageOverlay.querySelector('.image-viewer-caption');
        const searchOverlay = document.querySelector('.search-overlay');
        const searchInput = searchOverlay?.querySelector('.search-input');
        const searchResultsEl = searchOverlay?.querySelector('[data-search-results]');
        const searchStatusEl = searchOverlay?.querySelector('[data-search-status]');
        const searchCloseBtn = searchOverlay?.querySelector('.search-close-btn');
        const searchIndexUrl = searchIndexPath;
        const searchReady = searchOverlay && searchInput && searchResultsEl && searchStatusEl && searchCloseBtn;

        let currentUrl = '';
        const previewCache = new Map();
        let previewSourceEl = null;
        let previewOpenFrame = 0;
        let previewOverlayAnimation = null;
        let previewModalAnimation = null;
        let previewState = 'closed';
        let searchIndexPromise = null;
        let searchItems = [];
        let searchResults = [];
        let searchActiveIndex = -1;
        let searchSourceEl = null;
        let searchCloseTimer = 0;
        let searchState = 'idle';
        let imageViewerSourceEl = null;
        let imageViewerOverlayAnimation = null;
        let imageViewerShellAnimation = null;
        let imageViewerState = 'closed';
        let imageViewerMotion = {
          startX: 0,
          startY: 18,
          startScaleX: 0.86,
          startScaleY: 0.82,
          pinchScaleX: 0.68,
          pinchScaleY: 1.01,
          driftX: 0,
          driftY: -8,
          overshootScaleX: 1.01,
          overshootScaleY: 0.992,
        };
        let previewMotion = {
          startX: 0,
          startY: 24,
          startScaleX: 0.92,
          startScaleY: 0.88,
          pinchScaleX: 0.7,
          pinchScaleY: 1.02,
          driftX: 0,
          driftY: -10,
          overshootScaleX: 1.018,
          overshootScaleY: 0.988,
        };

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const syncScrollbarOffset = () => {
          const scrollbarWidth = Math.max(0, window.innerWidth - document.documentElement.clientWidth);
          document.documentElement.style.setProperty('--scrollbar-offset', `${scrollbarWidth}px`);
        };

        syncScrollbarOffset();
        window.addEventListener('resize', syncScrollbarOffset, { signal });

        function clearSearchCloseTimer() {
          if (!searchCloseTimer) return;
          window.clearTimeout(searchCloseTimer);
          searchCloseTimer = 0;
        }

        function getImageCaption(sourceEl) {
          const figureCaption = sourceEl.closest('figure')?.querySelector('figcaption')?.textContent?.trim();
          if (figureCaption) return figureCaption;
          return sourceEl.getAttribute('alt')?.trim() || '';
        }

        function rememberSourceImageHidden(sourceEl) {
          if (!(sourceEl instanceof HTMLImageElement)) return;
          sourceEl.dataset.imageViewerOpacity = sourceEl.style.opacity || '';
          sourceEl.style.opacity = '0';
        }

        function restoreSourceImageHidden(sourceEl = imageViewerSourceEl) {
          if (!(sourceEl instanceof HTMLImageElement)) return;
          sourceEl.style.opacity = sourceEl.dataset.imageViewerOpacity || '';
          delete sourceEl.dataset.imageViewerOpacity;
        }

        function openImageViewer(sourceEl) {
          if (!(sourceEl instanceof HTMLImageElement)) return;

          const imageSrc = sourceEl.currentSrc || sourceEl.src;
          if (!imageSrc) return;

          stopImageViewerAnimations();
          imageViewerSourceEl = sourceEl;
          imageViewerMedia.src = imageSrc;
          imageViewerMedia.alt = sourceEl.alt || '';

          const captionText = getImageCaption(sourceEl);
          imageViewerCaption.textContent = captionText;
          imageViewerCaption.hidden = !captionText;

          syncScrollbarOffset();
          document.body.classList.add('image-view-open');
          imageOverlay.classList.add('is-open');
          rememberSourceImageHidden(sourceEl);
          setImageViewerMotion(sourceEl);
          applyImageViewerStartStyles();

          requestAnimationFrame(() => {
            if (!imageOverlay.classList.contains('is-open')) return;
            animateImageViewerOpen();
          });

          window.setTimeout(() => {
            if (imageOverlay.classList.contains('is-open')) imageViewerCloseBtn.focus();
          }, 120);
        }

        function escapeHtml(value) {
          return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function normalizeSearchText(value) {
          return String(value ?? '').toLocaleLowerCase().normalize('NFKC').trim();
        }

        function buildSearchIndexEntry(item) {
          const titleText = normalizeSearchText(item.title);
          const descriptionText = normalizeSearchText(item.description);
          const excerptText = normalizeSearchText(item.excerpt);
          const tagsText = normalizeSearchText((item.tags ?? []).join(' '));
          const slugText = normalizeSearchText(item.slug);

          return {
            ...item,
            _search: {
              titleText,
              descriptionText,
              excerptText,
              tagsText,
              slugText,
            },
          };
        }

        function setSearchStatus(message) {
          if (!searchStatusEl) return;
          searchStatusEl.textContent = message;
        }

        function syncActiveSearchResult() {
          if (!searchResultsEl) return;

          const nodes = searchResultsEl.querySelectorAll('[data-search-result]');
          nodes.forEach((node, index) => {
            const isActive = index === searchActiveIndex;
            node.classList.toggle('is-active', isActive);
            node.setAttribute('aria-selected', isActive ? 'true' : 'false');
            if (isActive) {
              node.scrollIntoView({ block: 'nearest' });
            }
          });
        }

        function setActiveSearchResult(nextIndex) {
          if (!searchResults.length) {
            searchActiveIndex = -1;
            return;
          }

          const safeIndex = (nextIndex + searchResults.length) % searchResults.length;
          searchActiveIndex = safeIndex;
          syncActiveSearchResult();
        }

        function renderSearchResults() {
          if (!searchResultsEl || !searchInput) return;

          const rawQuery = searchInput.value.trim();

          if (searchState === 'loading') {
            setSearchStatus('正在整理搜索索引...');
            searchResultsEl.innerHTML = `
              <div class="search-empty">
                <p>第一次打开时会稍等一下，随后就会很快。</p>
              </div>
            `;
            return;
          }

          if (searchState === 'error') {
            setSearchStatus('搜索索引加载失败。');
            searchResultsEl.innerHTML = `
              <div class="search-empty">
                <p>暂时无法加载搜索内容，稍后再试试。</p>
              </div>
            `;
            return;
          }

          if (!searchResults.length) {
            setSearchStatus(rawQuery ? '没有找到匹配的文章。' : '最近更新');
            searchResultsEl.innerHTML = `
              <div class="search-empty">
                <p>${rawQuery ? '换个关键词试试，比如标题、标签或一句摘要。' : '还没有可以搜索的文章。'}</p>
              </div>
            `;
            return;
          }

          setSearchStatus(rawQuery ? `找到 ${searchResults.length} 篇相关文章` : '最近更新');
          searchResultsEl.innerHTML = searchResults.map((item, index) => {
            const summary = item.description || item.excerpt || '打开这篇文章继续阅读。';
            const tags = (item.tags ?? [])
              .slice(0, 3)
              .map((tag) => `<span class="search-chip">${escapeHtml(tag)}</span>`)
              .join('');

            return `
              <a
                href="${escapeHtml(item.href)}"
                class="search-result${index === searchActiveIndex ? ' is-active' : ''}"
                data-search-result
                data-index="${index}"
                aria-selected="${index === searchActiveIndex ? 'true' : 'false'}"
              >
                <div class="search-result-top">
                  <p class="search-result-title">${escapeHtml(item.title)}</p>
                  <span class="search-result-date">${escapeHtml(item.dateLabel)}</span>
                </div>
                <p class="search-result-summary">${escapeHtml(summary)}</p>
                <div class="search-result-meta">
                  <div class="search-chip-group">${tags}</div>
                  <span class="search-result-slug">/${escapeHtml(item.slug)}</span>
                </div>
              </a>
            `;
          }).join('');
        }

        function scoreSearchItem(item, fullQuery, tokens) {
          let score = 0;
          const { titleText, descriptionText, excerptText, tagsText, slugText } = item._search;

          if (titleText.includes(fullQuery)) score += 120 - Math.min(titleText.indexOf(fullQuery), 40);
          if (tagsText.includes(fullQuery)) score += 72 - Math.min(tagsText.indexOf(fullQuery), 30);
          if (descriptionText.includes(fullQuery)) score += 46 - Math.min(descriptionText.indexOf(fullQuery), 24);
          if (excerptText.includes(fullQuery)) score += 24;
          if (slugText.includes(fullQuery)) score += 18;

          for (const token of tokens) {
            if (!token) continue;
            if (titleText.includes(token)) score += 34;
            if (tagsText.includes(token)) score += 20;
            if (descriptionText.includes(token)) score += 12;
            if (excerptText.includes(token)) score += 8;
            if (slugText.includes(token)) score += 6;
          }

          return score;
        }

        function updateSearchResults(resetActive = true) {
          if (!searchInput) return;

          const fullQuery = normalizeSearchText(searchInput.value);
          const tokens = fullQuery.split(/\s+/).filter(Boolean);

          if (!fullQuery) {
            searchResults = searchItems.slice(0, 6);
          } else {
            searchResults = searchItems
              .map((item) => ({
                item,
                score: scoreSearchItem(item, fullQuery, tokens),
              }))
              .filter((entry) => entry.score > 0)
              .sort((left, right) => right.score - left.score || right.item.publishedAt - left.item.publishedAt)
              .slice(0, 8)
              .map((entry) => entry.item);
          }

          if (resetActive) {
            searchActiveIndex = searchResults.length ? 0 : -1;
          } else if (searchActiveIndex >= searchResults.length) {
            searchActiveIndex = searchResults.length ? searchResults.length - 1 : -1;
          }

          searchState = 'ready';
          renderSearchResults();
        }

        function ensureSearchIndex() {
          if (!searchReady) return Promise.resolve([]);
          if (searchItems.length) {
            updateSearchResults();
            return Promise.resolve(searchItems);
          }

          if (searchIndexPromise) return searchIndexPromise;

          searchState = 'loading';
          renderSearchResults();

          searchIndexPromise = fetch(searchIndexUrl)
            .then((response) => {
              if (!response.ok) throw new Error(`HTTP ${response.status}`);
              return response.json();
            })
            .then((items) => {
              searchItems = Array.isArray(items) ? items.map(buildSearchIndexEntry) : [];
              updateSearchResults();
              return searchItems;
            })
            .catch((error) => {
              searchIndexPromise = null;
              searchState = 'error';
              renderSearchResults();
              throw error;
            });

          return searchIndexPromise;
        }

        function openSearch(sourceEl) {
          if (!searchReady) return;
          if (searchOverlay.classList.contains('is-open')) {
            searchInput.focus({ preventScroll: true });
            searchInput.select();
            return;
          }

          if (overlay.classList.contains('is-open')) {
            closePreview();
            window.setTimeout(() => openSearch(sourceEl), prefersReducedMotion ? 0 : 220);
            return;
          }

          clearSearchCloseTimer();
          searchSourceEl = sourceEl instanceof HTMLElement ? sourceEl : null;
          syncScrollbarOffset();
          document.body.classList.add('search-lock');
          searchOverlay.setAttribute('aria-hidden', 'false');
          updateSearchResults();

          requestAnimationFrame(() => {
            searchOverlay.classList.add('is-open');
            document.body.classList.add('search-open');
          });

          ensureSearchIndex().catch(() => {});

          window.setTimeout(() => {
            searchInput.focus({ preventScroll: true });
            searchInput.select();
          }, prefersReducedMotion ? 0 : 120);
        }

        function closeSearch(restoreFocus = true) {
          if (!searchReady || !searchOverlay.classList.contains('is-open')) return;

          clearSearchCloseTimer();
          searchOverlay.classList.remove('is-open');
          document.body.classList.remove('search-open');

          const finishSearchClose = () => {
            document.body.classList.remove('search-lock');
            searchOverlay.setAttribute('aria-hidden', 'true');
            syncScrollbarOffset();

            if (restoreFocus && searchSourceEl instanceof HTMLElement && searchSourceEl.isConnected) {
              searchSourceEl.focus({ preventScroll: true });
            }

