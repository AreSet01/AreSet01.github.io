---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

const searchIndexPath = `${import.meta.env.BASE_URL ?? '/'}search-index.json`;

interface Props {
  title: string;
  description?: string;
}

const { title, description = '梦付千秋 - 日常记录与技术分享' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4efe3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
    <div class="search-overlay" id="site-search" aria-hidden="true">
      <div class="search-modal" role="dialog" aria-modal="true" aria-labelledby="search-title">
        <div class="search-panel">
          <div class="search-header">
            <div class="search-heading">
              <p class="eyebrow">Command Palette</p>
              <h2 class="search-title" id="search-title">搜索文章</h2>
            </div>
            <button class="search-close-btn" type="button" aria-label="关闭搜索">
              Esc
            </button>
          </div>
          <label class="search-input-shell" for="site-search-input">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.6"></circle>
              <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
            </svg>
            <input
              id="site-search-input"
              class="search-input"
              type="search"
              placeholder="搜索标题、标签或摘要..."
              autocomplete="off"
              spellcheck="false"
            />
          </label>
          <div class="search-status" data-search-status>输入关键词，或直接浏览最近更新。</div>
          <div class="search-results" data-search-results></div>
          <div class="search-footer">
            <div class="search-footer-item">
              <span class="search-kbd">↑</span>
              <span class="search-kbd">↓</span>
              <span>切换结果</span>
            </div>
            <div class="search-footer-item">
              <span class="search-kbd">Enter</span>
              <span>打开文章</span>
            </div>
            <div class="search-footer-item">
              <span class="search-kbd">Esc</span>
              <span>关闭面板</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script define:vars={{ searchIndexPath }}>
      (() => {
        const sparkleColors = [
          '#7cb3f0', '#5a9ee6', '#a8d0f8',
          '#f0a8c8', '#e88ab0', '#f8c8dc',
          '#c8a0e0', '#b8d8f8', '#f0b8d8',
          '#93c5fd', '#f9a8d4', '#c4b5fd',
        ];

        function sparkle(x, y, count) {
          const frag = document.createDocumentFragment();
          for (let i = 0; i < count; i += 1) {
            const el = document.createElement('div');
            const size = Math.random() * 6 + 3;
            const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.6;
            const distance = Math.random() * 100 + 40;
            const color = sparkleColors[Math.floor(Math.random() * sparkleColors.length)];
            const delay = Math.random() * 80;
            const shape = Math.random() > 0.5 ? '50%' : `${2 + Math.random() * 3}px`;

            Object.assign(el.style, {
              position: 'fixed',
              left: `${x - size / 2}px`,
              top: `${y - size / 2}px`,
              width: `${size}px`,
              height: `${size}px`,
              borderRadius: shape,
              background: color,
              pointerEvents: 'none',
              zIndex: '9999',
              boxShadow: `0 0 ${size + 4}px ${color}`,
              opacity: '1',
              transition: 'none',
            });

            frag.appendChild(el);

            window.setTimeout(() => {
              requestAnimationFrame(() => {
                const gravity = 20 + Math.random() * 30;
                Object.assign(el.style, {
                  transition: 'transform 1.2s cubic-bezier(0.22, 1, 0.36, 1), opacity 1.2s ease-out',
                  transform: `translate(${Math.cos(angle) * distance}px, ${Math.sin(angle) * distance + gravity}px) scale(0)`,
                  opacity: '0',
                });
              });
            }, delay);

            window.setTimeout(() => el.remove(), 1400);
          }

          document.body.appendChild(frag);
        }

        document.addEventListener('click', (event) => {
          const isPreviewInteraction =
            previewClickActive ||
            event.target.closest('[data-post-preview], .preview-overlay, .preview-close-btn, .preview-read-full');
          const isSearchInteraction = event.target.closest(
            '[data-search-trigger], .search-overlay, .search-close-btn, [data-search-result]'
          );

          if (isPreviewInteraction || isSearchInteraction) return;
          sparkle(event.clientX, event.clientY, 18);
        });

        let previewClickActive = false;
        document.addEventListener('click', (event) => {
          if (previewClickActive) {
            previewClickActive = false;
            return;
          }

          if (event.target.closest('.preview-overlay, .preview-close-btn, .preview-read-full, .search-overlay, .search-close-btn')) {
            return;
          }

          const el = event.target.closest('a, button, .tag-chip, .nav-link, .timeline-link, .btn-primary, .btn-secondary, .stat-card');
          if (!el) return;

          el.classList.remove('pop-active');
          void el.offsetWidth;
          el.classList.add('pop-active');
          el.addEventListener('animationend', () => el.classList.remove('pop-active'), { once: true });
        });

        const canvas = document.createElement('canvas');
        Object.assign(canvas.style, {
          position: 'fixed',
          inset: '0',
          zIndex: '0',
          pointerEvents: 'none',
          opacity: '0.55',
        });
        document.body.prepend(canvas);

        const ctx = canvas.getContext('2d');
        let viewportWidth = 0;
        let viewportHeight = 0;

        function resizeCanvas() {
          viewportWidth = canvas.width = window.innerWidth;
          viewportHeight = canvas.height = window.innerHeight;
        }

        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        if (ctx) {
          const dots = [];
          const dotCount = 32;
          const ambientColors = [
            'rgba(147,197,253,0.5)',
            'rgba(196,181,253,0.45)',
            'rgba(249,168,212,0.45)',
            'rgba(165,220,252,0.4)',
            'rgba(253,186,210,0.4)',
          ];

          for (let i = 0; i < dotCount; i += 1) {
            dots.push({
              x: Math.random() * viewportWidth,
              y: Math.random() * viewportHeight,
              r: Math.random() * 3 + 1.5,
              dx: (Math.random() - 0.5) * 0.3,
              dy: (Math.random() - 0.5) * 0.2 - 0.1,
              color: ambientColors[Math.floor(Math.random() * ambientColors.length)],
              phase: Math.random() * Math.PI * 2,
            });
          }

          function drawDots(time) {
            ctx.clearRect(0, 0, viewportWidth, viewportHeight);

            for (const dot of dots) {
              dot.x += dot.dx + Math.sin(time * 0.0005 + dot.phase) * 0.15;
              dot.y += dot.dy + Math.cos(time * 0.0004 + dot.phase) * 0.1;

              if (dot.x < -10) dot.x = viewportWidth + 10;
              if (dot.x > viewportWidth + 10) dot.x = -10;
              if (dot.y < -10) dot.y = viewportHeight + 10;
              if (dot.y > viewportHeight + 10) dot.y = -10;

              const pulse = 0.7 + Math.sin(time * 0.001 + dot.phase) * 0.3;

              ctx.beginPath();
              ctx.arc(dot.x, dot.y, dot.r * pulse, 0, Math.PI * 2);
              ctx.fillStyle = dot.color;
              ctx.fill();

              ctx.beginPath();
              ctx.arc(dot.x, dot.y, dot.r * pulse * 2.5, 0, Math.PI * 2);
              const gradient = ctx.createRadialGradient(dot.x, dot.y, 0, dot.x, dot.y, dot.r * pulse * 2.5);
              gradient.addColorStop(0, dot.color);
              gradient.addColorStop(1, 'transparent');
              ctx.fillStyle = gradient;
              ctx.fill();
            }

            requestAnimationFrame(drawDots);
          }

          requestAnimationFrame(drawDots);
        }

        const overlay = document.createElement('div');
        overlay.className = 'preview-overlay';
        overlay.innerHTML = `
          <div class="preview-modal" role="dialog" aria-modal="true" aria-labelledby="preview-title">
            <div class="preview-modal-header">
              <h2 class="preview-modal-title" id="preview-title"></h2>
              <button class="preview-close-btn" aria-label="关闭预览" type="button">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="3" y1="3" x2="13" y2="13"></line>
                  <line x1="13" y1="3" x2="3" y2="13"></line>
                </svg>
              </button>
            </div>
            <div class="preview-modal-body"></div>
            <div class="preview-modal-footer">
              <a class="btn-primary preview-read-full" href="#">阅读全文 -></a>
            </div>
          </div>
        `;
        document.body.appendChild(overlay);

        const modal = overlay.querySelector('.preview-modal');
        const titleEl = overlay.querySelector('.preview-modal-title');
        const bodyEl = overlay.querySelector('.preview-modal-body');
        const closeBtn = overlay.querySelector('.preview-close-btn');
        const readFullBtn = overlay.querySelector('.preview-read-full');
        const searchOverlay = document.querySelector('.search-overlay');
        const searchInput = searchOverlay?.querySelector('.search-input');
        const searchResultsEl = searchOverlay?.querySelector('[data-search-results]');
        const searchStatusEl = searchOverlay?.querySelector('[data-search-status]');
        const searchCloseBtn = searchOverlay?.querySelector('.search-close-btn');
        const searchIndexUrl = searchIndexPath;
        const searchReady = searchOverlay && searchInput && searchResultsEl && searchStatusEl && searchCloseBtn;

        let currentUrl = '';
        const previewCache = new Map();
        let previewSourceEl = null;
        let previewOpenFrame = 0;
        let previewOverlayAnimation = null;
        let previewModalAnimation = null;
        let previewState = 'closed';
        let searchIndexPromise = null;
        let searchItems = [];
        let searchResults = [];
        let searchActiveIndex = -1;
        let searchSourceEl = null;
        let searchCloseTimer = 0;
        let searchState = 'idle';
        let previewMotion = {
          startX: 0,
          startY: 24,
          startScaleX: 0.92,
          startScaleY: 0.88,
          pinchScaleX: 0.7,
          pinchScaleY: 1.02,
          driftX: 0,
          driftY: -10,
          overshootScaleX: 1.018,
          overshootScaleY: 0.988,
        };

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const syncScrollbarOffset = () => {
          const scrollbarWidth = Math.max(0, window.innerWidth - document.documentElement.clientWidth);
          document.documentElement.style.setProperty('--scrollbar-offset', `${scrollbarWidth}px`);
        };

        syncScrollbarOffset();
        window.addEventListener('resize', syncScrollbarOffset);

        function clearSearchCloseTimer() {
          if (!searchCloseTimer) return;
          window.clearTimeout(searchCloseTimer);
          searchCloseTimer = 0;
        }

        function escapeHtml(value) {
          return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function normalizeSearchText(value) {
          return String(value ?? '').toLocaleLowerCase().normalize('NFKC').trim();
        }

        function buildSearchIndexEntry(item) {
          const titleText = normalizeSearchText(item.title);
          const descriptionText = normalizeSearchText(item.description);
          const excerptText = normalizeSearchText(item.excerpt);
          const tagsText = normalizeSearchText((item.tags ?? []).join(' '));
          const slugText = normalizeSearchText(item.slug);

          return {
            ...item,
            _search: {
              titleText,
              descriptionText,
              excerptText,
              tagsText,
              slugText,
            },
          };
        }

        function setSearchStatus(message) {
          if (!searchStatusEl) return;
          searchStatusEl.textContent = message;
        }

        function syncActiveSearchResult() {
          if (!searchResultsEl) return;

          const nodes = searchResultsEl.querySelectorAll('[data-search-result]');
          nodes.forEach((node, index) => {
            const isActive = index === searchActiveIndex;
            node.classList.toggle('is-active', isActive);
            node.setAttribute('aria-selected', isActive ? 'true' : 'false');
            if (isActive) {
              node.scrollIntoView({ block: 'nearest' });
            }
          });
        }

        function setActiveSearchResult(nextIndex) {
          if (!searchResults.length) {
            searchActiveIndex = -1;
            return;
          }

          const safeIndex = (nextIndex + searchResults.length) % searchResults.length;
          searchActiveIndex = safeIndex;
          syncActiveSearchResult();
        }

        function renderSearchResults() {
          if (!searchResultsEl || !searchInput) return;

          const rawQuery = searchInput.value.trim();

          if (searchState === 'loading') {
            setSearchStatus('正在整理搜索索引...');
            searchResultsEl.innerHTML = `
              <div class="search-empty">
                <p>第一次打开时会稍等一下，随后就会很快。</p>
              </div>
            `;
            return;
          }

          if (searchState === 'error') {
            setSearchStatus('搜索索引加载失败。');
            searchResultsEl.innerHTML = `
              <div class="search-empty">
                <p>暂时无法加载搜索内容，稍后再试试。</p>
              </div>
            `;
            return;
          }

          if (!searchResults.length) {
            setSearchStatus(rawQuery ? '没有找到匹配的文章。' : '最近更新');
            searchResultsEl.innerHTML = `
              <div class="search-empty">
                <p>${rawQuery ? '换个关键词试试，比如标题、标签或一句摘要。' : '还没有可以搜索的文章。'}</p>
              </div>
            `;
            return;
          }

          setSearchStatus(rawQuery ? `找到 ${searchResults.length} 篇相关文章` : '最近更新');
          searchResultsEl.innerHTML = searchResults.map((item, index) => {
            const summary = item.description || item.excerpt || '打开这篇文章继续阅读。';
            const tags = (item.tags ?? [])
              .slice(0, 3)
              .map((tag) => `<span class="search-chip">${escapeHtml(tag)}</span>`)
              .join('');

            return `
              <a
                href="${escapeHtml(item.href)}"
                class="search-result${index === searchActiveIndex ? ' is-active' : ''}"
                data-search-result
                data-index="${index}"
                aria-selected="${index === searchActiveIndex ? 'true' : 'false'}"
              >
                <div class="search-result-top">
                  <p class="search-result-title">${escapeHtml(item.title)}</p>
                  <span class="search-result-date">${escapeHtml(item.dateLabel)}</span>
                </div>
                <p class="search-result-summary">${escapeHtml(summary)}</p>
                <div class="search-result-meta">
                  <div class="search-chip-group">${tags}</div>
                  <span class="search-result-slug">/${escapeHtml(item.slug)}</span>
                </div>
              </a>
            `;
          }).join('');
        }

        function scoreSearchItem(item, fullQuery, tokens) {
          let score = 0;
          const { titleText, descriptionText, excerptText, tagsText, slugText } = item._search;

          if (titleText.includes(fullQuery)) score += 120 - Math.min(titleText.indexOf(fullQuery), 40);
          if (tagsText.includes(fullQuery)) score += 72 - Math.min(tagsText.indexOf(fullQuery), 30);
          if (descriptionText.includes(fullQuery)) score += 46 - Math.min(descriptionText.indexOf(fullQuery), 24);
          if (excerptText.includes(fullQuery)) score += 24;
          if (slugText.includes(fullQuery)) score += 18;

          for (const token of tokens) {
            if (!token) continue;
            if (titleText.includes(token)) score += 34;
            if (tagsText.includes(token)) score += 20;
            if (descriptionText.includes(token)) score += 12;
            if (excerptText.includes(token)) score += 8;
            if (slugText.includes(token)) score += 6;
          }

          return score;
        }

        function updateSearchResults(resetActive = true) {
          if (!searchInput) return;

          const fullQuery = normalizeSearchText(searchInput.value);
          const tokens = fullQuery.split(/\s+/).filter(Boolean);

          if (!fullQuery) {
            searchResults = searchItems.slice(0, 6);
          } else {
            searchResults = searchItems
              .map((item) => ({
                item,
                score: scoreSearchItem(item, fullQuery, tokens),
              }))
              .filter((entry) => entry.score > 0)
              .sort((left, right) => right.score - left.score || right.item.publishedAt - left.item.publishedAt)
              .slice(0, 8)
              .map((entry) => entry.item);
          }

          if (resetActive) {
            searchActiveIndex = searchResults.length ? 0 : -1;
          } else if (searchActiveIndex >= searchResults.length) {
            searchActiveIndex = searchResults.length ? searchResults.length - 1 : -1;
          }

          searchState = 'ready';
          renderSearchResults();
        }

        function ensureSearchIndex() {
          if (!searchReady) return Promise.resolve([]);
          if (searchItems.length) {
            updateSearchResults();
            return Promise.resolve(searchItems);
          }

          if (searchIndexPromise) return searchIndexPromise;

          searchState = 'loading';
          renderSearchResults();

          searchIndexPromise = fetch(searchIndexUrl)
            .then((response) => {
              if (!response.ok) throw new Error(`HTTP ${response.status}`);
              return response.json();
            })
            .then((items) => {
              searchItems = Array.isArray(items) ? items.map(buildSearchIndexEntry) : [];
              updateSearchResults();
              return searchItems;
            })
            .catch((error) => {
              searchIndexPromise = null;
              searchState = 'error';
              renderSearchResults();
              throw error;
            });

          return searchIndexPromise;
        }

        function openSearch(sourceEl) {
          if (!searchReady) return;
          if (searchOverlay.classList.contains('is-open')) {
            searchInput.focus({ preventScroll: true });
            searchInput.select();
            return;
          }

          if (overlay.classList.contains('is-open')) {
            closePreview();
            window.setTimeout(() => openSearch(sourceEl), prefersReducedMotion ? 0 : 220);
            return;
          }

          clearSearchCloseTimer();
          searchSourceEl = sourceEl instanceof HTMLElement ? sourceEl : null;
          syncScrollbarOffset();
          document.body.classList.add('search-lock');
          searchOverlay.setAttribute('aria-hidden', 'false');
          updateSearchResults();

          requestAnimationFrame(() => {
            searchOverlay.classList.add('is-open');
            document.body.classList.add('search-open');
          });

          ensureSearchIndex().catch(() => {});

          window.setTimeout(() => {
            searchInput.focus({ preventScroll: true });
            searchInput.select();
          }, prefersReducedMotion ? 0 : 120);
        }

        function closeSearch(restoreFocus = true) {
          if (!searchReady || !searchOverlay.classList.contains('is-open')) return;

          clearSearchCloseTimer();
          searchOverlay.classList.remove('is-open');
          document.body.classList.remove('search-open');

          const finishSearchClose = () => {
            document.body.classList.remove('search-lock');
            searchOverlay.setAttribute('aria-hidden', 'true');
            syncScrollbarOffset();

            if (restoreFocus && searchSourceEl instanceof HTMLElement && searchSourceEl.isConnected) {
              searchSourceEl.focus({ preventScroll: true });
            }

            searchSourceEl = null;
            searchCloseTimer = 0;
          };

          if (prefersReducedMotion) {
            finishSearchClose();
            return;
          }

          searchCloseTimer = window.setTimeout(finishSearchClose, 260);
        }

        function releaseAnimation(animation) {
          if (!animation) return;
          animation.onfinish = null;
          animation.oncancel = null;
          animation.cancel();
        }

        function stopPreviewAnimations() {
          releaseAnimation(previewOverlayAnimation);
          releaseAnimation(previewModalAnimation);
          previewOverlayAnimation = null;
          previewModalAnimation = null;
        }

        function resetPreviewMotion() {
          previewMotion = {
            startX: 0,
            startY: 24,
            startScaleX: 0.92,
            startScaleY: 0.88,
            pinchScaleX: 0.7,
            pinchScaleY: 1.02,
            driftX: 0,
            driftY: -10,
            overshootScaleX: 1.018,
            overshootScaleY: 0.988,
          };
        }

        function setPreviewMotion(sourceEl) {
          previewSourceEl = sourceEl instanceof Element ? sourceEl : null;
          if (!previewSourceEl) {
            resetPreviewMotion();
            return;
          }

          const sourceRect = previewSourceEl.getBoundingClientRect();
          const modalRect = modal.getBoundingClientRect();
          const sourceStyle = window.getComputedStyle(previewSourceEl);
          const startX = sourceRect.left + sourceRect.width / 2 - window.innerWidth / 2;
          const startY = sourceRect.top + sourceRect.height / 2 - window.innerHeight / 2;
          const scaleRatioX = sourceRect.width / Math.max(modalRect.width, 1);
          const scaleRatioY = sourceRect.height / Math.max(modalRect.height, 1);
          const sourceRadius = parseFloat(sourceStyle.borderTopLeftRadius) || 16;
          const startScaleX = Math.max(0.24, Math.min(0.84, scaleRatioX));
          const startScaleY = Math.max(0.16, Math.min(0.78, scaleRatioY));
          const pinchScaleX = Math.max(0.18, startScaleX * 0.62);
          const pinchScaleY = Math.min(1.08, Math.max(0.52, startScaleY * 1.25));
          const driftX = startX * -0.16;
          const driftY = startY * -0.1 - Math.max(8, sourceRadius * 0.2);
          const overshootScaleX = 1.018;
          const overshootScaleY = 0.988;

          previewMotion = {
            startX,
            startY,
            startScaleX,
            startScaleY,
            pinchScaleX,
            pinchScaleY,
            driftX,
            driftY,
            overshootScaleX,
            overshootScaleY,
          };
        }

        function applyPreviewStartStyles() {
          const { startX, startY, startScaleX, startScaleY } = previewMotion;
          overlay.style.opacity = '0';
          modal.style.transform = `translate3d(${startX}px, ${startY}px, 0) scale(${startScaleX}, ${startScaleY})`;
          modal.style.opacity = '0';
        }

        function applyPreviewOpenStyles() {
          overlay.style.opacity = '1';
          modal.style.transform = 'translate3d(0, 0, 0) scale(1, 1)';
          modal.style.opacity = '1';
        }

        function clearPreviewInlineStyles() {
          overlay.style.removeProperty('opacity');
          modal.style.removeProperty('transform');
          modal.style.removeProperty('opacity');
        }

        function animatePreviewOpen() {
          stopPreviewAnimations();

          if (prefersReducedMotion) {
            applyPreviewOpenStyles();
            previewState = 'open';
            return;
          }

          const {
            startX,
            startY,
            startScaleX,
            startScaleY,
            pinchScaleX,
            pinchScaleY,
            driftX,
            driftY,
            overshootScaleX,
            overshootScaleY,
          } = previewMotion;
          previewState = 'opening';

          previewOverlayAnimation = overlay.animate(
            [{ opacity: 0 }, { opacity: 1 }],
            {
              duration: 360,
              easing: 'cubic-bezier(0.2, 0.82, 0.2, 1)',
              fill: 'both',
            }
          );

          previewModalAnimation = modal.animate(
            [
              {
                transform: `translate3d(${startX}px, ${startY}px, 0) scale(${startScaleX}, ${startScaleY})`,
                opacity: 0.04,
              },
              {
                transform: `translate3d(${(startX * 0.4).toFixed(2)}px, ${(startY * 0.58).toFixed(2)}px, 0) scale(${pinchScaleX.toFixed(3)}, ${pinchScaleY.toFixed(3)})`,
                opacity: 0.78,
                offset: 0.42,
              },
              {
                transform: `translate3d(${driftX.toFixed(2)}px, ${driftY.toFixed(2)}px, 0) scale(${overshootScaleX.toFixed(3)}, ${overshootScaleY.toFixed(3)})`,
                opacity: 1,
                offset: 0.78,
              },
              {
                transform: 'translate3d(0, 0, 0) scale(1, 1)',
                opacity: 1,
              },
            ],
            {
              duration: 760,
              easing: 'cubic-bezier(0.18, 0.86, 0.22, 1)',
              fill: 'both',
            }
          );

          previewOverlayAnimation.onfinish = () => {
            overlay.style.opacity = '1';
            releaseAnimation(previewOverlayAnimation);
            previewOverlayAnimation = null;
          };

          previewOverlayAnimation.oncancel = () => {
            previewOverlayAnimation = null;
          };

          previewModalAnimation.onfinish = () => {
            applyPreviewOpenStyles();
            releaseAnimation(previewModalAnimation);
            previewModalAnimation = null;
            previewState = 'open';
          };

          previewModalAnimation.oncancel = () => {
            previewModalAnimation = null;
          };
        }

        function openPreview(url, sourceEl) {
          cancelAnimationFrame(previewOpenFrame);
          stopPreviewAnimations();
          currentUrl = url;
          setPreviewMotion(sourceEl);
          readFullBtn.href = url;
          titleEl.textContent = '加载中...';
          bodyEl.innerHTML = `
            <div class="preview-loading">
              <div class="preview-spinner"></div>
              <span>正在加载预览...</span>
            </div>
          `;
          bodyEl.scrollTop = 0;
          syncScrollbarOffset();
          document.body.classList.add('preview-lock');
          document.body.classList.add('preview-active');
          overlay.classList.add('is-open');
          applyPreviewStartStyles();

          previewOpenFrame = requestAnimationFrame(() => {
            document.body.classList.add('preview-open');
            animatePreviewOpen();
            previewOpenFrame = 0;
          });

          window.setTimeout(() => {
            if (overlay.classList.contains('is-open')) closeBtn.focus();
          }, 180);

          if (previewCache.has(url)) {
            renderPreview(previewCache.get(url));
            return;
          }

          fetch(url)
            .then((response) => {
              if (!response.ok) throw new Error(`HTTP ${response.status}`);
              return response.text();
            })
            .then((html) => {
              const parsed = parsePostHtml(html);
              previewCache.set(url, parsed);
              if (currentUrl === url) renderPreview(parsed);
            })
            .catch(() => {
              if (currentUrl !== url) return;

              titleEl.textContent = '加载失败';
              bodyEl.innerHTML = `
                <div class="preview-error">
                  <div style="font-size: 2rem; opacity: 0.5;">!</div>
                  <p style="font-size: 0.95rem; line-height: 1.5;">
                    无法加载文章预览。<br>
                    <a href="${url}" style="color: var(--accent-strong); text-decoration: underline;">改为阅读全文</a>
                  </p>
                </div>
              `;
            });
        }

        function parsePostHtml(html) {
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const titleNode = doc.querySelector('.section-title');
          const title = titleNode ? titleNode.textContent.trim() : '';
          const proseEl = doc.querySelector('.prose');
          const content = proseEl ? proseEl.innerHTML : '<p>无法解析文章内容。</p>';
          return { title, content };
        }

        function renderPreview({ title, content }) {
          titleEl.textContent = title || '文章预览';
          bodyEl.innerHTML = `<div class="prose">${content}</div>`;
        }

        function finishPreviewClose(restoreFocusEl) {
          stopPreviewAnimations();
          overlay.classList.remove('is-open');
          document.body.classList.remove('preview-open');
          document.body.classList.remove('preview-lock');
          document.body.classList.remove('preview-active');
          syncScrollbarOffset();
          clearPreviewInlineStyles();
          resetPreviewMotion();
          currentUrl = '';
          previewState = 'closed';
          previewSourceEl = null;

          if (restoreFocusEl instanceof HTMLElement && restoreFocusEl.isConnected) {
            restoreFocusEl.focus({ preventScroll: true });
          }
        }

        function closePreview() {
          if (!overlay.classList.contains('is-open') || previewState === 'closing') return;

          const restoreFocusEl = previewSourceEl;
          cancelAnimationFrame(previewOpenFrame);
          stopPreviewAnimations();

          if (prefersReducedMotion) {
            finishPreviewClose(restoreFocusEl);
            return;
          }

          previewState = 'closing';
          document.body.classList.remove('preview-open');
          document.body.classList.remove('preview-active');
          applyPreviewOpenStyles();

          previewOverlayAnimation = overlay.animate(
            [{ opacity: 1 }, { opacity: 0 }],
            {
              duration: 220,
              easing: 'cubic-bezier(0.36, 0, 0.2, 1)',
              fill: 'both',
            }
          );

          previewModalAnimation = modal.animate(
            [
              {
                transform: 'translate3d(0, 0, 0) scale(1, 1)',
                opacity: 1,
              },
              {
                transform: `translate3d(${(previewMotion.driftX * 0.22).toFixed(2)}px, ${(previewMotion.driftY * 0.22).toFixed(2)}px, 0) scale(0.982, 1.012)`,
                opacity: 1,
                offset: 0.18,
              },
              {
                transform: `translate3d(${(previewMotion.startX * 0.42).toFixed(2)}px, ${(previewMotion.startY * 0.58).toFixed(2)}px, 0) scale(${previewMotion.pinchScaleX.toFixed(3)}, ${previewMotion.pinchScaleY.toFixed(3)})`,
                opacity: 0.82,
                offset: 0.56,
              },
              {
                transform: `translate3d(${previewMotion.startX.toFixed(2)}px, ${previewMotion.startY.toFixed(2)}px, 0) scale(${previewMotion.startScaleX.toFixed(3)}, ${previewMotion.startScaleY.toFixed(3)})`,
                opacity: 0,
              },
            ],
            {
              duration: 520,
              easing: 'cubic-bezier(0.4, 0, 0.14, 1)',
              fill: 'both',
            }
          );

          previewOverlayAnimation.onfinish = () => {
            overlay.style.opacity = '0';
            releaseAnimation(previewOverlayAnimation);
            previewOverlayAnimation = null;
          };

          previewOverlayAnimation.oncancel = () => {
            previewOverlayAnimation = null;
          };

          previewModalAnimation.onfinish = () => {
            finishPreviewClose(restoreFocusEl);
          };

          previewModalAnimation.oncancel = () => {
            previewModalAnimation = null;
          };
        }

        document.addEventListener('click', (event) => {
          if (event.ctrlKey || event.metaKey || event.shiftKey || event.button !== 0) return;

          const link = event.target.closest('[data-post-preview]');
          if (!link) return;

          const previewUrl = link.getAttribute('data-post-preview');
          if (!previewUrl) return;

          event.preventDefault();
          previewClickActive = true;
          openPreview(previewUrl, link);
        }, true);

        overlay.addEventListener('click', (event) => {
          if (event.target === overlay) closePreview();
        });

        closeBtn.addEventListener('click', (event) => {
          event.stopPropagation();
          closePreview();
        });

        if (searchReady) {
          document.querySelectorAll('[data-search-trigger]').forEach((trigger) => {
            trigger.addEventListener('click', (event) => {
              event.preventDefault();
              openSearch(trigger);
            });
          });

          searchOverlay.addEventListener('click', (event) => {
            if (event.target === searchOverlay) closeSearch();
          });

          searchCloseBtn.addEventListener('click', (event) => {
            event.preventDefault();
            closeSearch();
          });

          searchInput.addEventListener('input', () => {
            updateSearchResults();
          });

          searchInput.addEventListener('keydown', (event) => {
            if (event.key === 'ArrowDown') {
              event.preventDefault();
              setActiveSearchResult(searchActiveIndex + 1);
              return;
            }

            if (event.key === 'ArrowUp') {
              event.preventDefault();
              setActiveSearchResult(searchActiveIndex - 1);
              return;
            }

            if (event.key === 'Enter' && searchActiveIndex >= 0 && searchResults[searchActiveIndex]) {
              event.preventDefault();
              window.location.assign(searchResults[searchActiveIndex].href);
              return;
            }

            if (event.key === 'Escape') {
              event.preventDefault();
              closeSearch();
            }
          });

          searchResultsEl.addEventListener('mousemove', (event) => {
            const target = event.target.closest('[data-search-result]');
            if (!target) return;
            setActiveSearchResult(Number(target.getAttribute('data-index')));
          });

          searchResultsEl.addEventListener('click', (event) => {
            const target = event.target.closest('[data-search-result]');
            if (!target) return;
            closeSearch(false);
          });
        }

        document.addEventListener('keydown', (event) => {
          const isSearchShortcut =
            event.key.toLowerCase() === 'k' && (event.ctrlKey || event.metaKey);

          if (isSearchShortcut && !event.shiftKey && !event.altKey) {
            event.preventDefault();
            if (searchOverlay?.classList.contains('is-open')) {
              closeSearch();
            } else {
              openSearch(document.querySelector('[data-search-trigger]'));
            }
            return;
          }

          if (event.key === 'Escape' && searchOverlay?.classList.contains('is-open')) {
            closeSearch();
            return;
          }

          if (event.key === 'Escape' && overlay.classList.contains('is-open')) closePreview();
        });

        /* ========== 5. 鼠标光标追踪光晕 ========== */
        if (!document.querySelector('.cursor-glow') && window.matchMedia('(pointer: fine)').matches) {
          const glow = document.createElement('div');
          glow.className = 'cursor-glow';
          document.body.appendChild(glow);

          let glowX = 0, glowY = 0;
          let targetX = 0, targetY = 0;
          let rafId = 0;
          let isVisible = false;

          function updateGlow() {
            glowX += (targetX - glowX) * 0.12;
            glowY += (targetY - glowY) * 0.12;
            glow.style.transform = `translate3d(${glowX - 140}px, ${glowY - 140}px, 0)`;
            rafId = requestAnimationFrame(updateGlow);
          }
          rafId = requestAnimationFrame(updateGlow);

          document.addEventListener('mousemove', (e) => {
            targetX = e.clientX;
            targetY = e.clientY;
            if (!isVisible) {
              isVisible = true;
              glow.classList.add('is-visible');
            }
          });

          document.addEventListener('mouseleave', () => {
            isVisible = false;
            glow.classList.remove('is-visible', 'is-hovering');
          });

          document.addEventListener('mouseover', (e) => {
            const interactive = e.target.closest('a, button, .tag-chip, .nav-link, .btn-primary, .btn-secondary, .stat-card, .timeline-link, [data-post-preview]');
            if (interactive) {
              glow.classList.add('is-hovering');
            } else {
              glow.classList.remove('is-hovering');
            }
          });
        }
      })();
    </script>
  </body>
</html>
