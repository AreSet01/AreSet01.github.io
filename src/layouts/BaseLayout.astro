---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

const searchIndexPath = `${import.meta.env.BASE_URL ?? '/'}search-index.json`;

interface Props {
  title: string;
  description?: string;
}

const { title, description = '梦付千秋 - 日常记录与技术分享' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3ebd9" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Patrick+Hand&family=Ma+Shan+Zheng&family=Noto+Sans+SC:wght@400;500;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <script is:inline>
      (function(){
        var runtimeKey = '__areSetThemeRuntimeBound__';
        var themeTransitionTimer = 0;

        function getStoredTheme() {
          try {
            var stored = localStorage.getItem('theme');
            return stored === 'dark' || stored === 'light' ? stored : null;
          } catch (error) {
            return null;
          }
        }

        function resolveTheme(explicitTheme) {
          if (explicitTheme === 'dark' || explicitTheme === 'light') return explicitTheme;
          var storedTheme = getStoredTheme();
          if (storedTheme) return storedTheme;
          return window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light';
        }

        function syncThemeColor(theme) {
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#14110d' : '#f3ebd9');
          document.documentElement.style.colorScheme = theme;
        }

        function syncGiscusTheme(theme) {
          var giscusTheme = theme === 'dark' ? 'dark_dimmed' : 'light';
          var script = document.querySelector('script[src="https://giscus.app/client.js"]');
          if (script) script.setAttribute('data-theme', giscusTheme);

          var frame = document.querySelector('iframe.giscus-frame');
          if (frame && frame.contentWindow) {
            frame.contentWindow.postMessage(
              { giscus: { setConfig: { theme: giscusTheme } } },
              'https://giscus.app'
            );
          }
        }

        function markThemeSwitching() {
          document.documentElement.classList.add('theme-switching');
          window.clearTimeout(themeTransitionTimer);
          themeTransitionTimer = window.setTimeout(function() {
            document.documentElement.classList.remove('theme-switching');
          }, 980);
        }

        function applyTheme(explicitTheme) {
          var nextTheme = resolveTheme(explicitTheme);
          document.documentElement.setAttribute('data-theme', nextTheme);
          syncThemeColor(nextTheme);

          requestAnimationFrame(function() { syncGiscusTheme(nextTheme); });
          window.setTimeout(function() { syncGiscusTheme(nextTheme); }, 180);
          window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: nextTheme } }));
          return nextTheme;
        }

        function transitionTheme(nextTheme, sourceEl) {
          var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          if (
            prefersReducedMotion ||
            !sourceEl ||
            typeof document.startViewTransition !== 'function'
          ) {
            markThemeSwitching();
            applyTheme(nextTheme);
            return;
          }

          var rect = sourceEl.getBoundingClientRect();
          var x = rect.left + rect.width / 2;
          var y = rect.top + rect.height / 2;
          var endRadius = Math.hypot(
            Math.max(x, window.innerWidth - x),
            Math.max(y, window.innerHeight - y)
          );

          var transition = document.startViewTransition(function() {
            markThemeSwitching();
            applyTheme(nextTheme);
          });

          transition.ready
            .then(function() {
              document.documentElement.animate(
                {
                  clipPath: [
                    'circle(14px at ' + x + 'px ' + y + 'px)',
                    'circle(' + endRadius + 'px at ' + x + 'px ' + y + 'px)',
                  ],
                  opacity: [0.7, 1],
                  filter: ['blur(6px) brightness(0.94) saturate(0.92)', 'blur(0) brightness(1) saturate(1)'],
                },
                {
                  duration: 920,
                  easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
                  pseudoElement: '::view-transition-new(root)',
                }
              );
            })
            .catch(function() {});
        }

        window.__getPreferredTheme = resolveTheme;
        window.__applyTheme = applyTheme;
        window.__transitionTheme = transitionTheme;
        applyTheme();

        if (window[runtimeKey]) return;

        document.addEventListener('astro:after-swap', function() {
          applyTheme();
        });

        document.addEventListener('astro:page-load', function() {
          applyTheme();
        });

        var media = window.matchMedia('(prefers-color-scheme:dark)');
        if (media && typeof media.addEventListener === 'function') {
          media.addEventListener('change', function() {
            if (getStoredTheme()) return;
            applyTheme();
          });
        }

        window[runtimeKey] = true;
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
    <div class="seal-floating" aria-hidden="true">
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="sealRough" x="-10%" y="-10%" width="120%" height="120%">
            <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="5" />
            <feDisplacementMap in="SourceGraphic" scale="1.8" />
          </filter>
        </defs>
        <g filter="url(#sealRough)">
          <rect x="6" y="6" width="88" height="88" rx="3" fill="#a8392b" />
          <rect x="11" y="11" width="78" height="78" rx="2" fill="none" stroke="#f7f1e1" stroke-width="2.4" opacity="0.94" />
          <line x1="50" y1="11" x2="50" y2="89" stroke="#f7f1e1" stroke-width="1.4" opacity="0.46" />
          <line x1="11" y1="50" x2="89" y2="50" stroke="#f7f1e1" stroke-width="1.4" opacity="0.46" />
          <text x="30" y="46" font-family="'Ma Shan Zheng', serif" font-size="32" fill="#f7f1e1" font-weight="500" text-anchor="middle">梦</text>
          <text x="70" y="46" font-family="'Ma Shan Zheng', serif" font-size="32" fill="#f7f1e1" font-weight="500" text-anchor="middle">付</text>
          <text x="30" y="80" font-family="'Ma Shan Zheng', serif" font-size="32" fill="#f7f1e1" font-weight="500" text-anchor="middle">千</text>
          <text x="70" y="80" font-family="'Ma Shan Zheng', serif" font-size="32" fill="#f7f1e1" font-weight="500" text-anchor="middle">秋</text>
        </g>
      </svg>
    </div>
    <div class="search-overlay" id="site-search" aria-hidden="true">
      <div class="search-modal" role="dialog" aria-modal="true" aria-labelledby="search-title">
        <div class="search-panel" data-lenis-prevent>
          <div class="search-header">
            <div class="search-heading">
              <p class="eyebrow">Command Palette</p>
              <h2 class="search-title" id="search-title">搜索文章</h2>
            </div>
            <button class="search-close-btn" type="button" aria-label="关闭搜索">
              Esc
            </button>
          </div>
          <label class="search-input-shell" for="site-search-input">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.6"></circle>
              <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
            </svg>
            <input
              id="site-search-input"
              class="search-input"
              type="search"
              placeholder="搜索标题、标签或摘要..."
              autocomplete="off"
              spellcheck="false"
            />
          </label>
          <div class="search-status" data-search-status>输入关键词，或直接浏览最近更新。</div>
          <div class="search-results" data-search-results></div>
          <div class="search-footer">
            <div class="search-footer-item">
              <span class="search-kbd">↑</span>
              <span class="search-kbd">↓</span>
              <span>切换结果</span>
            </div>
            <div class="search-footer-item">
              <span class="search-kbd">Enter</span>
              <span>打开文章</span>
            </div>
            <div class="search-footer-item">
              <span class="search-kbd">Esc</span>
              <span>关闭面板</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import CustomEase from 'gsap/CustomEase';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger, CustomEase);

      // Create a premium "ink-wash" custom ease
      CustomEase.create("ink", "0.25, 1, 0.5, 1");
      CustomEase.create("ink-out", "0.34, 1.56, 0.64, 1"); // Slight overshoot like ink spreading

      window.gsap = gsap;
      window.ScrollTrigger = ScrollTrigger;

      function initSmoothScroll() {
        // Force animations for aesthetic priority (bypass OS reduced motion settings)
        // if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const lenis = new Lenis({
          duration: 1.1, // Faster
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // Custom premium easing
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 0.8, // Make wheel slightly heavier
        });

        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });

        gsap.ticker.lagSmoothing(0);

        // Store globally for potential destruction
        window.lenis = lenis;
      }

      // Initialize on first load
      initSmoothScroll();

      // Re-initialize after Astro View Transitions
      document.addEventListener('astro:after-swap', () => {
        if (window.lenis) {
          window.lenis.destroy();
        }
        initSmoothScroll();
      });

      // Page Load / Transition Animation (墨迹扩散展开)
      document.addEventListener('astro:page-load', () => {
        const main = document.querySelector('main');
        if (main) {
          gsap.fromTo(main, 
            { opacity: 0, y: 30, filter: 'blur(12px)', scale: 0.98 }, 
            { opacity: 1, y: 0, filter: 'blur(0px)', scale: 1, duration: 1.0, ease: "ink", clearProps: "all" }
          );
        }

        initMagneticButtons();
      });

      // Magnetic Micro-interactions
      function initMagneticButtons() {
        // if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        
        const magneticElements = document.querySelectorAll('.btn-primary, .btn-secondary, .nav-link, .tag-chip');
        
        magneticElements.forEach(el => {
          // Store original transform if any
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            // Calculate pull distance (0.3 is the magnetic strength)
            const x = (e.clientX - rect.left - rect.width / 2) * 0.25;
            const y = (e.clientY - rect.top - rect.height / 2) * 0.25;
            
            gsap.to(el, { 
              x, y, 
              duration: 0.6, 
              ease: 'power3.out',
              overwrite: "auto"
            });
          });
          
          el.addEventListener('mouseleave', () => {
            gsap.to(el, { 
              x: 0, y: 0, 
              duration: 0.9, 
              ease: 'elastic.out(1, 0.4)', // Squish/jelly effect on release
              clearProps: "x,y",
              overwrite: "auto"
            });
          });
        });
      }

      // Modal Stagger Animations (弹窗时间轴错落展开)
      document.addEventListener('astro:page-load', () => {
        const modals = document.querySelectorAll('.search-overlay, .preview-overlay, .image-viewer-overlay');
        
        modals.forEach(overlay => {
          const observer = new MutationObserver((mutations) => {
            mutations.forEach(mutation => {
              if (mutation.attributeName === 'class') {
                const isOpen = overlay.classList.contains('is-open');
                const modalInner = overlay.querySelector('.search-modal, .preview-modal, .image-viewer-shell');
                
                if (isOpen && modalInner && window.gsap) {
                  // Find elements to stagger
                  const children = Array.from(modalInner.children);
                  
                  // Reset first
                  gsap.set(children, { y: 20, opacity: 0, filter: 'blur(8px)' });
                  
                  // Animate in
                  gsap.to(children, {
                    y: 0,
                    opacity: 1,
                    filter: 'blur(0px)',
                    duration: 0.85,
                    stagger: 0.06,
                    ease: "ink",
                    delay: 0.05,
                    overwrite: "auto"
                  });
                }
              }
            });
          });
          
          observer.observe(overlay, { attributes: true });
        });
      });
    </script>
    <script is:inline define:vars={{ searchIndexPath }}>
      (() => {
        const cleanupKey = '__areSetSiteUiCleanup__';
        const initKey = '__areSetSiteUiInit__';
        const listenerKey = '__areSetSiteUiPageLoadBound__';

        function initSiteUi() {
          const previousCleanup = window[cleanupKey];
          if (typeof previousCleanup === 'function') previousCleanup();

          const controller = new AbortController();
          const { signal } = controller;
          let isDisposed = false;
          let ambientFrame = 0;
          let revealObserver = null;

          document.querySelectorAll('canvas[data-ambient-canvas]').forEach((node) => node.remove());
          document.querySelectorAll('.preview-overlay[data-generated-preview]').forEach((node) => node.remove());
          document.querySelectorAll('.image-viewer-overlay[data-generated-image-viewer]').forEach((node) => node.remove());
          document.body.classList.remove('search-lock', 'search-open', 'preview-lock', 'preview-active', 'preview-open', 'image-view-open');
          document.documentElement.style.setProperty('--scrollbar-offset', '0px');



        function sparkle(x, y, count) {
          const isDarkTheme = document.documentElement.getAttribute('data-theme') === 'dark';
          const sparkleColors = isDarkTheme ? [
            '#ffffff', '#f2f2f2', '#e6e6e6', '#d9d9d9',
            '#cccccc', '#bfbfbf', '#b3b3b3', '#a6a6a6'
          ] : [
            '#1a1814', '#0d0c09', '#3a352c',
            '#2a2620', '#1f1c18', '#161310',
            '#4a4338', '#6b6353', '#564e42',
          ];

          const frag = document.createDocumentFragment();
          const splotchCount = Math.max(3, Math.round(count * 0.35));

          for (let i = 0; i < count; i += 1) {
            const el = document.createElement('div');
            const size = Math.random() * 5 + 2;
            const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.5;
            const distance = Math.random() * 56 + 14;
            const color = sparkleColors[Math.floor(Math.random() * sparkleColors.length)];
            const delay = Math.random() * 60;
            const elongation = 0.55 + Math.random() * 0.5;

            Object.assign(el.style, {
              position: 'fixed',
              left: `${x - size / 2}px`,
              top: `${y - size / 2}px`,
              width: `${size}px`,
              height: `${size * elongation}px`,
              borderRadius: '50%',
              background: color,
              pointerEvents: 'none',
              zIndex: '9999',
              boxShadow: `0 0 ${size + 3}px ${color}`,
              opacity: '0.78',
              filter: 'blur(0.3px)',
              transition: 'none',
              transform: `rotate(${(angle * 180 / Math.PI).toFixed(1)}deg)`,
              transformOrigin: 'center center',
            });

            frag.appendChild(el);

            window.setTimeout(() => {
              requestAnimationFrame(() => {
                const drift = 4 + Math.random() * 8;
                Object.assign(el.style, {
                  transition: 'transform 1.05s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.05s cubic-bezier(0.22, 0.8, 0.3, 1), filter 1.05s ease-out',
                  transform: `translate(${Math.cos(angle) * distance}px, ${Math.sin(angle) * distance + drift}px) rotate(${(angle * 180 / Math.PI).toFixed(1)}deg) scale(${(0.4 + Math.random() * 0.3).toFixed(2)})`,
                  opacity: '0',
                  filter: 'blur(2.5px)',
                });
              });
            }, delay);

            window.setTimeout(() => el.remove(), 1300);
          }

          for (let i = 0; i < splotchCount; i += 1) {
            const dot = document.createElement('div');
            const dSize = Math.random() * 8 + 6;
            const dx = (Math.random() - 0.5) * 22;
            const dy = (Math.random() - 0.5) * 22;
            const dColor = sparkleColors[Math.floor(Math.random() * sparkleColors.length)];

            Object.assign(dot.style, {
              position: 'fixed',
              left: `${x - dSize / 2 + dx}px`,
              top: `${y - dSize / 2 + dy}px`,
              width: `${dSize}px`,
              height: `${dSize}px`,
              borderRadius: '50%',
              background: `radial-gradient(circle, ${dColor} 0%, ${dColor} 35%, transparent 75%)`,
              pointerEvents: 'none',
              zIndex: '9998',
              opacity: '0.5',
              filter: 'blur(1.6px)',
              transform: 'scale(0.6)',
              transition: 'none',
            });

            frag.appendChild(dot);

            window.setTimeout(() => {
              requestAnimationFrame(() => {
                Object.assign(dot.style, {
                  transition: 'transform 920ms cubic-bezier(0.16, 1, 0.3, 1), opacity 920ms ease-out, filter 920ms ease-out',
                  transform: `scale(${1.4 + Math.random() * 0.6})`,
                  opacity: '0',
                  filter: 'blur(4px)',
                });
              });
            }, Math.random() * 40);

            window.setTimeout(() => dot.remove(), 1100);
          }

          document.body.appendChild(frag);
        }

        function initRevealUp() {
          if (!window.gsap || !window.ScrollTrigger) {
            // Fallback if GSAP isn't loaded yet
            setTimeout(initRevealUp, 50);
            return;
          }

          const { gsap, ScrollTrigger } = window;
          const revealNodes = gsap.utils.toArray('.reveal-up');
          
          if (!revealNodes.length) return;

          // Parallax effect for hero section (水墨扩散展开感)
          const heroCopy = document.querySelector('.home-hero-copy');
          const heroRail = document.querySelector('.home-rail');
          
          if (heroCopy && heroRail) {
            gsap.fromTo(heroCopy, 
              { y: 40, opacity: 0, filter: 'blur(12px)' }, 
              { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.2, ease: "ink", delay: 0.1 }
            );
            gsap.fromTo(heroRail, 
              { x: 20, opacity: 0 }, 
              { x: 0, opacity: 1, duration: 1.0, ease: "ink", delay: 0.2 }
            );

            // Parallax on scroll
            gsap.to(heroCopy, {
              y: -80,
              opacity: 0,
              ease: "none",
              immediateRender: false, // Fix bug where it disappears after scrolling down
              scrollTrigger: {
                trigger: ".home-hero",
                start: "top top",
                end: "bottom top",
                scrub: true
              }
            });
          }

          // Replace old CSS reveal with GSAP staggered reveal
          revealNodes.forEach((node) => {
            // Remove old classes to prevent conflicts
            node.classList.remove('reveal-up');
            
            // Set initial state
            gsap.set(node, { y: 30, opacity: 0, filter: 'blur(8px)' });

            ScrollTrigger.create({
              trigger: node,
              start: "top 85%", // Reveal when top of element hits 85% of viewport
              onEnter: () => {
                gsap.to(node, {
                  y: 0,
                  opacity: 1,
                  filter: 'blur(0px)',
                  duration: 0.85, // Faster reveal
                  ease: "ink",
                  overwrite: "auto"
                });
              },
              onLeaveBack: () => {
                // Optional: hide again when scrolling back up
                gsap.to(node, {
                  y: 15,
                  opacity: 0,
                  filter: 'blur(4px)',
                  duration: 0.8,
                  ease: "power2.inOut",
                  overwrite: "auto"
                });
              }
            });
          });
        }

        initRevealUp();

        document.addEventListener('click', (event) => {
          const isPreviewOpen =
            previewClickActive ||
            event.target.closest('[data-post-preview]');
          const isSearchInteraction = event.target.closest(
            '[data-search-trigger], .search-close-btn, [data-search-result]'
          );
          const isImageInteraction = event.target.closest(
            '.prose img, .image-viewer-overlay, .image-viewer-close'
          );

          if (isPreviewOpen || isSearchInteraction || isImageInteraction) return;
          sparkle(event.clientX, event.clientY, 18);
        }, { signal });

        let previewClickActive = false;
        document.addEventListener('click', (event) => {
          if (previewClickActive) {
            previewClickActive = false;
            return;
          }

          if (event.target.closest('.preview-overlay, .preview-close-btn, .preview-read-full, .search-overlay, .search-close-btn')) {
            return;
          }

          const el = event.target.closest('a, button, .tag-chip, .nav-link, .timeline-link, .btn-primary, .btn-secondary, .stat-card');
          if (!el) return;

          el.classList.remove('pop-active');
          void el.offsetWidth;
          el.classList.add('pop-active');
          el.addEventListener('animationend', () => el.classList.remove('pop-active'), { once: true, signal });
        }, { signal });

        const canvas = document.createElement('canvas');
        canvas.dataset.ambientCanvas = 'true';
        Object.assign(canvas.style, {
          position: 'fixed',
          inset: '0',
          zIndex: '0',
          pointerEvents: 'none',
          opacity: '0.55',
        });
        document.body.prepend(canvas);

        const ctx = canvas.getContext('2d');
        let viewportWidth = 0;
        let viewportHeight = 0;

        function resizeCanvas() {
          viewportWidth = canvas.width = window.innerWidth;
          viewportHeight = canvas.height = window.innerHeight;
        }

        resizeCanvas();
        window.addEventListener('resize', resizeCanvas, { signal });

        if (ctx) {
          const dots = [];
          const dotCount = 32;
          const ambientColors = [
            'rgba(26,24,20,0.28)',
            'rgba(13,12,9,0.32)',
            'rgba(58,53,44,0.24)',
            'rgba(42,38,32,0.26)',
            'rgba(168,57,43,0.18)',
          ];

          for (let i = 0; i < dotCount; i += 1) {
            dots.push({
              x: Math.random() * viewportWidth,
              y: Math.random() * viewportHeight,
              r: Math.random() * 3 + 1.5,
              dx: (Math.random() - 0.5) * 0.3,
              dy: (Math.random() - 0.5) * 0.2 - 0.1,
              color: ambientColors[Math.floor(Math.random() * ambientColors.length)],
              phase: Math.random() * Math.PI * 2,
            });
          }

          function drawDots(time) {
            ctx.clearRect(0, 0, viewportWidth, viewportHeight);

            for (const dot of dots) {
              dot.x += dot.dx + Math.sin(time * 0.0005 + dot.phase) * 0.15;
              dot.y += dot.dy + Math.cos(time * 0.0004 + dot.phase) * 0.1;

              if (dot.x < -10) dot.x = viewportWidth + 10;
              if (dot.x > viewportWidth + 10) dot.x = -10;
              if (dot.y < -10) dot.y = viewportHeight + 10;
              if (dot.y > viewportHeight + 10) dot.y = -10;

              const pulse = 0.7 + Math.sin(time * 0.001 + dot.phase) * 0.3;

              ctx.beginPath();
              ctx.arc(dot.x, dot.y, dot.r * pulse, 0, Math.PI * 2);
              ctx.fillStyle = dot.color;
              ctx.fill();

              ctx.beginPath();
              ctx.arc(dot.x, dot.y, dot.r * pulse * 2.5, 0, Math.PI * 2);
              const gradient = ctx.createRadialGradient(dot.x, dot.y, 0, dot.x, dot.y, dot.r * pulse * 2.5);
              gradient.addColorStop(0, dot.color);
              gradient.addColorStop(1, 'transparent');
              ctx.fillStyle = gradient;
              ctx.fill();
