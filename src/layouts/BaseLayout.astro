        }

        function closeImageViewer() {
          if (!imageOverlay.classList.contains('is-open') || imageViewerState === 'closing') return;

          const restoreFocusEl = imageViewerSourceEl;
          stopImageViewerAnimations();

          if (prefersReducedMotion) {
            finishImageViewerClose(restoreFocusEl);
            return;
          }

          const {
            startX,
            startY,
            startScaleX,
            startScaleY,
            pinchScaleX,
            pinchScaleY,
            driftX,
            driftY,
          } = imageViewerMotion;

          imageViewerState = 'closing';
          applyImageViewerOpenStyles();

          imageViewerOverlayAnimation = imageOverlay.animate(
            [{ opacity: 1 }, { opacity: 0 }],
            {
              duration: 220,
              easing: 'cubic-bezier(0.36, 0, 0.2, 1)',
              fill: 'both',
            }
          );

          imageViewerShellAnimation = imageViewerShell.animate(
            [
              {
                transform: 'translate3d(0, 0, 0) scale(1, 1)',
                opacity: 1,
              },
              {
                transform: `translate3d(${(driftX * 0.2).toFixed(2)}px, ${(driftY * 0.2).toFixed(2)}px, 0) scale(0.986, 1.006)`,
                opacity: 1,
                offset: 0.18,
              },
              {
                transform: `translate3d(${(startX * 0.38).toFixed(2)}px, ${(startY * 0.56).toFixed(2)}px, 0) scale(${pinchScaleX.toFixed(3)}, ${pinchScaleY.toFixed(3)})`,
                opacity: 0.82,
                offset: 0.56,
              },
              {
                transform: `translate3d(${startX.toFixed(2)}px, ${startY.toFixed(2)}px, 0) scale(${startScaleX.toFixed(3)}, ${startScaleY.toFixed(3)})`,
                opacity: 0,
              },
            ],
            {
              duration: 460,
              easing: 'cubic-bezier(0.4, 0, 0.14, 1)',
              fill: 'both',
            }
          );

          imageViewerOverlayAnimation.onfinish = () => {
            imageOverlay.style.opacity = '0';
            releaseAnimation(imageViewerOverlayAnimation);
            imageViewerOverlayAnimation = null;
          };

          imageViewerOverlayAnimation.oncancel = () => {
            imageViewerOverlayAnimation = null;
          };

          imageViewerShellAnimation.onfinish = () => {
            finishImageViewerClose(restoreFocusEl);
          };

          imageViewerShellAnimation.oncancel = () => {
            imageViewerShellAnimation = null;
          };
        }

        function stopPreviewAnimations() {
          releaseAnimation(previewOverlayAnimation);
          releaseAnimation(previewModalAnimation);
          previewOverlayAnimation = null;
          previewModalAnimation = null;
        }

        function resetPreviewMotion() {
          previewMotion = {
            startX: 0,
            startY: 24,
            startScaleX: 0.92,
            startScaleY: 0.88,
            pinchScaleX: 0.7,
            pinchScaleY: 1.02,
            driftX: 0,
            driftY: -10,
            overshootScaleX: 1.018,
            overshootScaleY: 0.988,
          };
        }

        function setPreviewMotion(sourceEl) {
          previewSourceEl = sourceEl instanceof Element ? sourceEl : null;
          if (!previewSourceEl) {
