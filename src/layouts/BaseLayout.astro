---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '梦付千秋 - 日常记录与技术分享' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4efe3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
    <script>
      (() => {
        /* ========== 1. 点击烟花特效 ========== */
        const colors = [
          '#7cb3f0', '#5a9ee6', '#a8d0f8',
          '#f0a8c8', '#e88ab0', '#f8c8dc',
          '#c8a0e0', '#b8d8f8', '#f0b8d8',
          '#93c5fd', '#f9a8d4', '#c4b5fd',
        ];

        function sparkle(x, y, count) {
          const frag = document.createDocumentFragment();
          for (let i = 0; i < count; i++) {
            const el = document.createElement('div');
            const size = Math.random() * 6 + 3;
            const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.6;
            const dist = Math.random() * 100 + 40;
            const color = colors[Math.floor(Math.random() * colors.length)];
            const delay = Math.random() * 80;
            const shape = Math.random() > 0.5 ? '50%' : `${2 + Math.random() * 3}px`;
            Object.assign(el.style, {
              position: 'fixed',
              left: x + 'px',
              top: y + 'px',
              width: size + 'px',
              height: size + 'px',
              borderRadius: shape,
              background: color,
              pointerEvents: 'none',
              zIndex: '9999',
              boxShadow: `0 0 ${size + 4}px ${color}`,
              opacity: '1',
              transition: 'none',
            });
            frag.appendChild(el);

            setTimeout(() => {
              requestAnimationFrame(() => {
                const gravity = 20 + Math.random() * 30;
                Object.assign(el.style, {
                  transition: `transform 1.2s cubic-bezier(0.22, 1, 0.36, 1), opacity 1.2s ease-out`,
                  transform: `translate(${Math.cos(angle) * dist}px, ${Math.sin(angle) * dist + gravity}px) scale(0)`,
                  opacity: '0',
                });
              });
            }, delay);

            setTimeout(() => el.remove(), 1400);
          }
          document.body.appendChild(frag);
        }

        document.addEventListener('click', (e) => {
          sparkle(e.clientX, e.clientY, 18);
        });

        /* ========== 2. 可点击元素弹出动画 ========== */
        let previewClickActive = false;
        document.addEventListener('click', (e) => {
          if (previewClickActive) { previewClickActive = false; return; }
          const el = e.target.closest('a, button, .tag-chip, .nav-link, .timeline-link, .btn-primary, .btn-secondary, .stat-card');
          if (!el) return;
          el.classList.remove('pop-active');
          void el.offsetWidth;
          el.classList.add('pop-active');
          el.addEventListener('animationend', () => el.classList.remove('pop-active'), { once: true });
        });

        /* ========== 3. 页面氛围粒子 ========== */
        const canvas = document.createElement('canvas');
        Object.assign(canvas.style, {
          position: 'fixed',
          inset: '0',
          zIndex: '0',
          pointerEvents: 'none',
          opacity: '0.55',
        });
        document.body.prepend(canvas);
        const ctx = canvas.getContext('2d');
        let w, h;

        function resize() {
          w = canvas.width = window.innerWidth;
          h = canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        const dots = [];
        const DOT_COUNT = 32;
        const ambientColors = [
          'rgba(147,197,253,0.5)',   // blue
          'rgba(196,181,253,0.45)',   // purple
          'rgba(249,168,212,0.45)',   // pink
          'rgba(165,220,252,0.4)',    // light blue
          'rgba(253,186,210,0.4)',    // light pink
        ];

        for (let i = 0; i < DOT_COUNT; i++) {
          dots.push({
            x: Math.random() * w,
            y: Math.random() * h,
            r: Math.random() * 3 + 1.5,
            dx: (Math.random() - 0.5) * 0.3,
            dy: (Math.random() - 0.5) * 0.2 - 0.1,
            color: ambientColors[Math.floor(Math.random() * ambientColors.length)],
            phase: Math.random() * Math.PI * 2,
          });
        }

        function drawDots(t) {
          ctx.clearRect(0, 0, w, h);
          for (const d of dots) {
            d.x += d.dx + Math.sin(t * 0.0005 + d.phase) * 0.15;
            d.y += d.dy + Math.cos(t * 0.0004 + d.phase) * 0.1;
            if (d.x < -10) d.x = w + 10;
            if (d.x > w + 10) d.x = -10;
            if (d.y < -10) d.y = h + 10;
            if (d.y > h + 10) d.y = -10;

            const pulse = 0.7 + Math.sin(t * 0.001 + d.phase) * 0.3;
            ctx.beginPath();
            ctx.arc(d.x, d.y, d.r * pulse, 0, Math.PI * 2);
            ctx.fillStyle = d.color;
            ctx.fill();

            ctx.beginPath();
            ctx.arc(d.x, d.y, d.r * pulse * 2.5, 0, Math.PI * 2);
            const g = ctx.createRadialGradient(d.x, d.y, 0, d.x, d.y, d.r * pulse * 2.5);
            g.addColorStop(0, d.color);
            g.addColorStop(1, 'transparent');
            ctx.fillStyle = g;
            ctx.fill();
          }
          requestAnimationFrame(drawDots);
        }
        requestAnimationFrame(drawDots);

        /* ========== 4. 文章预览模态框 ========== */
        const overlay = document.createElement('div');
        overlay.className = 'preview-overlay';
        overlay.innerHTML = `
          <div class="preview-modal" role="dialog" aria-modal="true" aria-labelledby="preview-title">
            <div class="preview-modal-header">
              <h2 class="preview-modal-title" id="preview-title"></h2>
              <button class="preview-close-btn" aria-label="关闭预览" type="button">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/>
                </svg>
              </button>
            </div>
            <div class="preview-modal-body"></div>
            <div class="preview-modal-footer">
              <a class="btn-primary preview-read-full" href="#">阅读全文 →</a>
            </div>
          </div>
        `;
        document.body.appendChild(overlay);

        const modal = overlay.querySelector('.preview-modal');
        const titleEl = overlay.querySelector('.preview-modal-title');
        const bodyEl = overlay.querySelector('.preview-modal-body');
        const closeBtn = overlay.querySelector('.preview-close-btn');
        const readFullBtn = overlay.querySelector('.preview-read-full');
        let currentUrl = '';
        const previewCache = new Map();
        let previewSourceEl = null;
        let previewCleanupTimer = 0;
        let previewOpenFrame = 0;

        function syncPreviewScrollbar() {
          const scrollbarWidth = Math.max(window.innerWidth - document.documentElement.clientWidth, 0);
          document.documentElement.style.setProperty('--preview-scrollbar-width', `${scrollbarWidth}px`);
        }

        function resetPreviewMotion() {
          modal.style.removeProperty('--preview-start-x');
          modal.style.removeProperty('--preview-start-y');
          modal.style.removeProperty('--preview-start-scale');
        }

        function setPreviewMotion(sourceEl) {
          previewSourceEl = sourceEl instanceof Element ? sourceEl : null;
          if (!previewSourceEl) {
            resetPreviewMotion();
            return;
          }

          const sourceRect = previewSourceEl.getBoundingClientRect();
          const modalRect = modal.getBoundingClientRect();
          const startX = sourceRect.left + sourceRect.width / 2 - window.innerWidth / 2;
          const startY = sourceRect.top + sourceRect.height / 2 - window.innerHeight / 2;
          const scaleRatioX = sourceRect.width / Math.max(modalRect.width, 1);
          const scaleRatioY = sourceRect.height / Math.max(modalRect.height, 1);
          const startScale = Math.max(0.32, Math.min(0.92, Math.sqrt(scaleRatioX * scaleRatioY)));

          modal.style.setProperty('--preview-start-x', `${startX.toFixed(2)}px`);
          modal.style.setProperty('--preview-start-y', `${startY.toFixed(2)}px`);
          modal.style.setProperty('--preview-start-scale', startScale.toFixed(3));
        }
        function openPreview(url, sourceEl) {
          window.clearTimeout(previewCleanupTimer);
          cancelAnimationFrame(previewOpenFrame);
          syncPreviewScrollbar();
          currentUrl = url;
          setPreviewMotion(sourceEl);
          readFullBtn.href = url;
          titleEl.textContent = '加载中…';
          bodyEl.innerHTML = `
            <div class="preview-loading">
              <div class="preview-spinner"></div>
              <span>正在加载预览…</span>
            </div>
          `;
          bodyEl.scrollTop = 0;
          document.body.classList.add('preview-open');
          previewOpenFrame = requestAnimationFrame(() => {
            overlay.classList.add('is-open');
            previewOpenFrame = 0;
          });
          setTimeout(() => closeBtn.focus(), 100);

          if (previewCache.has(url)) {
            renderPreview(previewCache.get(url));
            return;
          }

          fetch(url)
            .then(res => {
              if (!res.ok) throw new Error(`HTTP ${res.status}`);
              return res.text();
            })
            .then(html => {
              const parsed = parsePostHtml(html);
              previewCache.set(url, parsed);
              if (currentUrl === url) renderPreview(parsed);
            })
            .catch(() => {
              if (currentUrl === url) {
                titleEl.textContent = '加载失败';
                bodyEl.innerHTML = `
                  <div class="preview-error">
                    <div style="font-size:2rem;opacity:0.5">!</div>
                    <p style="font-size:0.95rem;line-height:1.5">
                      无法加载文章预览<br>
                      <a href="${url}" style="color:var(--accent-strong);text-decoration:underline">点击这里直接阅读</a>
                    </p>
                  </div>
                `;
              }
            });
        }

        function parsePostHtml(html) {
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const titleNode = doc.querySelector('.section-title');
          const title = titleNode ? titleNode.textContent.trim() : '';
          const proseEl = doc.querySelector('.prose');
          const content = proseEl ? proseEl.innerHTML : '<p>无法解析文章内容。</p>';
          return { title, content };
        }

        function renderPreview({ title, content }) {
          titleEl.textContent = title || '文章预览';
          bodyEl.innerHTML = `<div class="prose">${content}</div>`;
        }

        function closePreview() {
          const restoreFocusEl = previewSourceEl;
          overlay.classList.remove('is-open');
          currentUrl = '';
          cancelAnimationFrame(previewOpenFrame);
          window.clearTimeout(previewCleanupTimer);
          previewCleanupTimer = window.setTimeout(() => {
            if (overlay.classList.contains('is-open')) return;
            document.body.classList.remove('preview-open');
            document.documentElement.style.setProperty('--preview-scrollbar-width', '0px');
            resetPreviewMotion();
            previewSourceEl = null;
            if (restoreFocusEl instanceof HTMLElement && restoreFocusEl.isConnected) {
              restoreFocusEl.focus({ preventScroll: true });
            }
          }, 420);
        }

        // 拦截 PostCard 点击（capture 阶段，优先于 pop 动画）
        document.addEventListener('click', (e) => {
          if (e.ctrlKey || e.metaKey || e.shiftKey || e.button !== 0) return;
          const link = e.target.closest('[data-post-preview]');
          if (!link) return;
          const previewUrl = link.getAttribute('data-post-preview');
          if (!previewUrl) return;
          e.preventDefault();
          previewClickActive = true;
          openPreview(previewUrl, link);
        }, true);

        // 点击遮罩关闭
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) closePreview();
        });

        // 关闭按钮
        closeBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          closePreview();
        });

        // Escape 关闭
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && overlay.classList.contains('is-open')) closePreview();
        });
      })();
    </script>
  </body>
</html>
