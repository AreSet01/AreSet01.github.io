---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TagList from '../components/TagList.astro';
import Giscus from '../components/Giscus.astro';
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  locked?: boolean;
  passwordHash?: string;
  passwordHint?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  title,
  description,
  pubDate,
  tags = [],
  locked = false,
  passwordHash,
  passwordHint,
  headings = [],
} = Astro.props;
const isLocked = locked && Boolean(passwordHash);
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const hasToc = tocHeadings.length > 1;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="container-wide flex-1 pb-12 pt-6 md:pb-16">
    <article class="space-y-8" data-locked-post={isLocked ? 'true' : undefined} data-lock-key={isLocked ? passwordHash : undefined}>
      <header class="panel reveal-up mx-auto max-w-3xl overflow-hidden rounded-[20px] px-7 py-9 md:px-11 md:py-11">
        <div class="flex flex-wrap items-center gap-2.5 text-[0.78rem] font-medium text-[var(--muted)]">
          <a href="/archive" class="transition hover:text-[var(--accent-strong)]">Archive</a>
          <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
          <span>Published {formatDate(pubDate)}</span>
          {isLocked && <span class="lock-mark">LOCKED</span>}
        </div>
        <h1 class="section-title mt-5 max-w-3xl text-2xl md:text-[2rem] lg:text-[2.25rem]">{title}</h1>
        {description && (
          <p class="mt-4 max-w-2xl text-[0.98rem] leading-relaxed text-[var(--muted)]">{description}</p>
        )}
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <div class="stat-card min-w-[160px]">
            <p class="stat-label">发布日期</p>
            <p class="mt-1.5 text-[0.95rem] font-semibold text-[var(--text-strong)]">{formatDate(pubDate)}</p>
          </div>
          {tags.length > 0 && <TagList tags={tags} class="max-w-2xl" />}
        </div>
      </header>
      {isLocked && (
        <section class="lock-panel panel reveal-up px-7 py-8 md:px-10 md:py-10" data-lock-panel style="animation-delay: 120ms;">
          <p class="eyebrow">Protected Note</p>
          <h2 class="font-display mt-3 text-xl text-[var(--text-strong)]">输入密码可查看噢~</h2>
          {passwordHint && <p class="mt-3 text-[0.92rem] leading-relaxed text-[var(--muted)]">Hint: {passwordHint}</p>}
          <form class="mt-6 flex flex-col gap-3 sm:flex-row" data-lock-form>
            <input
              class="lock-input"
              type="password"
              name="password"
              placeholder="Password"
              autocomplete="current-password"
              required
            />
            <button class="btn-primary whitespace-nowrap" type="submit">Unlock</button>
          </form>
          <p class="lock-message mt-3 text-[0.84rem]" data-lock-message aria-live="polite"></p>
        </section>
      )}
      <div
        class={`post-reading-grid reveal-up ${hasToc ? 'has-toc' : ''}`}
        style="animation-delay: 120ms;"
        data-locked-content={isLocked ? 'true' : undefined}
        hidden={isLocked}
      >
        {hasToc && (
          <aside class="post-toc panel" aria-labelledby="post-toc-title">
            <div class="post-toc-inner">
              <p class="post-toc-kicker">On this page</p>
              <h2 id="post-toc-title" class="post-toc-title">目录</h2>
              <nav class="post-toc-nav" aria-label="文章目录">
                {tocHeadings.map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    class={`post-toc-link depth-${heading.depth}`}
                    data-toc-link={heading.slug}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}
        <div class="panel rounded-[20px] px-7 py-8 md:px-10 md:py-10">
          <div class="prose" data-post-prose>
            <slot />
          </div>
        </div>
      </div>
      <div class="reveal-up" style="animation-delay: 220ms;">
        <Giscus />
      </div>
    </article>
  </main>
  <Footer />
  {isLocked && (
    <script is:inline data-astro-rerun>
      (() => {
        const article = document.querySelector('[data-locked-post="true"]');
        const panel = document.querySelector('[data-lock-panel]');
        const content = document.querySelector('[data-locked-content="true"]');
        const form = document.querySelector('[data-lock-form]');
        const message = document.querySelector('[data-lock-message]');
        const expectedHash = article?.getAttribute('data-lock-key') || '';
        const storageKey = `post-unlocked:${location.pathname}:${expectedHash}`;
        const encoder = new TextEncoder();

        function getStoredUnlock() {
          try {
            return sessionStorage.getItem(storageKey) === '1';
          } catch {
            return false;
          }
        }

        function setStoredUnlock() {
          try {
            sessionStorage.setItem(storageKey, '1');
          } catch {
            // Some privacy modes block sessionStorage; unlocking still works for the current page.
          }
        }

        async function sha256(value) {
          const bytes = encoder.encode(value);
          if (!window.crypto?.subtle) {
            throw new Error('WebCrypto is unavailable');
          }
          const hashBuffer = await window.crypto.subtle.digest('SHA-256', bytes);
          return Array.from(new Uint8Array(hashBuffer))
            .map((byte) => byte.toString(16).padStart(2, '0'))
            .join('');
        }

        function unlock() {
          if (content) content.hidden = false;
          if (panel) panel.hidden = true;
          article?.setAttribute('data-locked-post', 'false');
        }

        if (!article || !panel || !content || !form || !expectedHash) return;
        if (form.dataset.lockBound === 'true') return;
        form.dataset.lockBound = 'true';

        if (getStoredUnlock()) {
          unlock();
          return;
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          const formData = new FormData(form);
          const password = String(formData.get('password') ?? '');
          if (!password) return;

          try {
            const digest = await sha256(password);
            if (digest === expectedHash) {
              setStoredUnlock();
              unlock();
              window.dispatchEvent(new CustomEvent('post-unlocked'));
            } else if (message) {
              message.textContent = 'Password is incorrect.';
            }
          } catch {
            if (message) {
              message.textContent = 'This browser cannot verify the password here.';
            }
          }
        });
      })();
    </script>
  )}
  <script is:inline>
    (() => {
      const cleanupKey = '__areSetPostTocCleanup__';
      const initKey = '__areSetPostTocInit__';
      const listenerKey = '__areSetPostTocPageLoadBound__';

      function initPostToc() {
        const previousCleanup = window[cleanupKey];
        if (typeof previousCleanup === 'function') previousCleanup();

        const toc = document.querySelector('.post-toc');
        const prose = document.querySelector('[data-post-prose]');
        if (!toc || !prose) {
          window[cleanupKey] = null;
          return;
        }

        const controller = new AbortController();
        const { signal } = controller;
        const links = Array.from(toc.querySelectorAll('[data-toc-link]'));
        const headings = links
          .map((link) => {
            const id = link.getAttribute('data-toc-link');
            const heading = id ? prose.querySelector(`#${CSS.escape(id)}`) : null;
            return heading ? { link, heading } : null;
          })
          .filter(Boolean);

        function setActive(id) {
          links.forEach((link) => {
            link.classList.toggle('is-active', link.getAttribute('data-toc-link') === id);
          });
        }

        links.forEach((link) => {
          link.addEventListener('click', () => {
            const id = link.getAttribute('data-toc-link');
            if (id) setActive(id);
          }, { signal });
        });

        if (!headings.length || !('IntersectionObserver' in window)) {
          const firstId = links[0]?.getAttribute('data-toc-link');
          if (firstId) setActive(firstId);
          window[cleanupKey] = () => controller.abort();
          return;
        }

        const visible = new Map();
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const id = entry.target.id;
            if (!id) return;
            if (entry.isIntersecting) {
              visible.set(id, entry.boundingClientRect.top);
            } else {
              visible.delete(id);
            }
          });

          if (visible.size > 0) {
            const [id] = Array.from(visible.entries()).sort((a, b) => a[1] - b[1])[0];
            setActive(id);
            return;
          }

          const current = headings
            .map((item) => item.heading)
            .filter((heading) => heading.getBoundingClientRect().top <= 120)
            .at(-1);
          if (current?.id) setActive(current.id);
        }, {
          rootMargin: '-18% 0px -70% 0px',
          threshold: [0, 1],
        });

        headings.forEach(({ heading }) => observer.observe(heading));

        window[cleanupKey] = () => {
          controller.abort();
          observer.disconnect();
        };
      }

      window[initKey] = initPostToc;
      initPostToc();

      if (!window[listenerKey]) {
        window.addEventListener('post-unlocked', () => {
          const init = window[initKey];
          if (typeof init === 'function') init();
        });

        document.addEventListener('astro:page-load', () => {
          const init = window[initKey];
          if (typeof init === 'function') init();
        });
        window[listenerKey] = true;
      }
    })();
  </script>
  <script is:inline>
    (() => {
      const cleanupKey = '__areSetPostEnhancementsCleanup__';
      const initKey = '__areSetPostEnhancementsInit__';
      const listenerKey = '__areSetPostEnhancementsPageLoadBound__';

      function initPostEnhancements() {
        const previousCleanup = window[cleanupKey];
        if (typeof previousCleanup === 'function') previousCleanup();

        const prose = document.querySelector('[data-post-prose]');
        if (!prose) {
          window[cleanupKey] = null;
          return;
        }

        const controller = new AbortController();
        const { signal } = controller;
        let lastFocus = null;
        let previewOverlay = null;
        const previewCache = new Map();

        function enhanceCodeBlocks() {
          prose.querySelectorAll('pre').forEach((pre) => {
            if (pre.dataset.codeEnhanced === 'true') return;
            const code = pre.querySelector('code');
            if (!code) return;

            pre.dataset.codeEnhanced = 'true';
            const className = code.className || '';
            const languageMatch = className.match(/(?:language|lang)-([a-z0-9_+#.-]+)/i);
            const language = (languageMatch?.[1] || pre.getAttribute('data-language') || 'code').toLowerCase();

            const toolbar = document.createElement('div');
            toolbar.className = 'code-block-toolbar';

            const label = document.createElement('span');
            label.className = 'code-block-language';
            label.textContent = language;

            const copyButton = document.createElement('button');
            copyButton.className = 'code-copy-button';
            copyButton.type = 'button';
            copyButton.textContent = 'Copy';
            copyButton.setAttribute('aria-label', '复制代码');

            copyButton.addEventListener('click', async () => {
              const text = code.textContent || '';
              try {
                await navigator.clipboard.writeText(text);
                copyButton.textContent = 'Copied';
                window.setTimeout(() => {
                  copyButton.textContent = 'Copy';
                }, 1400);
              } catch {
                copyButton.textContent = 'Failed';
                window.setTimeout(() => {
                  copyButton.textContent = 'Copy';
                }, 1400);
              }
            }, { signal });

            toolbar.append(label, copyButton);
            pre.prepend(toolbar);
          });
        }

        function setupEasterAnchors() {
          const easterNodes = prose.querySelectorAll('[data-easter-anchor], [data-easter], [id^="egg-"], [id^="easter-"]');
          easterNodes.forEach((node, index) => {
            if (!(node instanceof HTMLElement)) return;
            const explicitId = node.getAttribute('data-easter-anchor') || node.id;
            const id = explicitId || `egg-${index + 1}`;
            node.id = id;
            node.dataset.easterAnchor = id;
            node.classList.add('easter-anchor-content');
          });
        }

        function ensurePreviewOverlay() {
          if (previewOverlay?.isConnected) return previewOverlay;

          previewOverlay = document.createElement('div');
          previewOverlay.className = 'reference-preview-overlay';
          previewOverlay.setAttribute('aria-hidden', 'true');
          previewOverlay.innerHTML = `
            <div class="reference-preview-modal" role="dialog" aria-modal="true" aria-labelledby="reference-preview-title">
              <div class="reference-preview-header">
                <div>
                  <p class="reference-preview-kicker">Reference Preview</p>
                  <h2 class="reference-preview-title" id="reference-preview-title"></h2>
                  <p class="reference-preview-source"></p>
                </div>
                <button class="reference-preview-close" type="button" aria-label="关闭引用预览">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <line x1="3" y1="3" x2="13" y2="13"></line>
                    <line x1="13" y1="3" x2="3" y2="13"></line>
                  </svg>
                </button>
              </div>
              <div class="reference-preview-body"></div>
            </div>
          `;
          document.body.appendChild(previewOverlay);

          previewOverlay.addEventListener('click', (event) => {
            if (event.target === previewOverlay) closePreview();
          }, { signal });

          previewOverlay.querySelector('.reference-preview-close')?.addEventListener('click', closePreview, { signal });

          return previewOverlay;
        }

        function closePreview() {
          if (!previewOverlay) return;
          previewOverlay.classList.remove('is-open');
          previewOverlay.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('reference-preview-open');
          if (lastFocus instanceof HTMLElement && lastFocus.isConnected) {
            lastFocus.focus({ preventScroll: true });
          }
          lastFocus = null;
        }

        function getHeadingRank(node) {
          const match = node?.tagName?.match(/^H([1-6])$/);
          return match ? Number(match[1]) : 7;
        }

        function sanitizeFragment(root) {
          root.querySelectorAll('script, style, iframe').forEach((node) => node.remove());
          root.querySelectorAll('[id]').forEach((node) => {
            node.removeAttribute('id');
          });
          return root;
        }

        function extractReferenceSection(target, ownerDocument) {
          const fragment = ownerDocument.createDocumentFragment();
          const rank = getHeadingRank(target);
          fragment.appendChild(target.cloneNode(true));

          let next = target.nextElementSibling;
          let count = 0;
          while (next && count < 18) {
            if (getHeadingRank(next) <= rank) break;
            fragment.appendChild(next.cloneNode(true));
            next = next.nextElementSibling;
            count += 1;
          }

          const wrapper = ownerDocument.createElement('div');
          wrapper.appendChild(fragment);
          return sanitizeFragment(wrapper);
        }

        function renderPreview({ title, source, content, isEaster = false }) {
          const overlay = ensurePreviewOverlay();
          const modal = overlay.querySelector('.reference-preview-modal');
          const titleEl = overlay.querySelector('.reference-preview-title');
          const sourceEl = overlay.querySelector('.reference-preview-source');
          const bodyEl = overlay.querySelector('.reference-preview-body');
          if (!modal || !titleEl || !sourceEl || !bodyEl) return;

          titleEl.textContent = title || (isEaster ? '隐藏片段' : '引用片段');
          sourceEl.textContent = source || '';
          bodyEl.replaceChildren(content);
          overlay.classList.add('is-open');
          overlay.setAttribute('aria-hidden', 'false');
          document.body.classList.add('reference-preview-open');
          overlay.querySelector('.reference-preview-close')?.focus({ preventScroll: true });
        }

        function renderLoading(source) {
          const wrapper = document.createElement('div');
          wrapper.className = 'reference-preview-state';
          wrapper.textContent = '正在加载引用片段...';
          renderPreview({ title: '引用片段', source, content: wrapper });
        }

        function renderError(source) {
          const wrapper = document.createElement('div');
          wrapper.className = 'reference-preview-state';
          wrapper.textContent = '无法读取这个引用片段。';
          renderPreview({ title: '引用片段', source, content: wrapper });
        }

        function getSourceLabel(url) {
          if (url.pathname === window.location.pathname) return `当前文章 · ${url.hash}`;
          return `${url.pathname}${url.hash}`;
        }

        async function getTargetFromUrl(url) {
          const id = decodeURIComponent(url.hash.slice(1));
          if (!id) return null;

          if (url.origin === window.location.origin && url.pathname === window.location.pathname) {
            const target = prose.querySelector(`#${CSS.escape(id)}`) || document.getElementById(id);
            return target ? { target, doc: document, title: document.title } : null;
          }

          const cacheKey = `${url.pathname}${url.search}`;
          let doc = previewCache.get(cacheKey);
          if (!doc) {
            const response = await fetch(url.pathname + url.search);
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            const html = await response.text();
            doc = new DOMParser().parseFromString(html, 'text/html');
            previewCache.set(cacheKey, doc);
          }

          const remoteProse = doc.querySelector('.prose');
          const target = remoteProse?.querySelector(`#${CSS.escape(id)}`) || doc.getElementById(id);
          return target ? { target, doc, title: doc.title } : null;
        }

        async function openReferencePreview(url, sourceEl) {
          lastFocus = sourceEl instanceof HTMLElement ? sourceEl : document.activeElement;
          renderLoading(getSourceLabel(url));

          try {
            const result = await getTargetFromUrl(url);
            if (!result) {
              renderError(getSourceLabel(url));
              return;
            }

            const { target, doc, title } = result;
            const isEaster = target instanceof HTMLElement && Boolean(target.dataset.easterAnchor);
            const content = extractReferenceSection(target, doc);
            renderPreview({
              title: target.getAttribute('data-easter-title') || target.textContent?.trim()?.slice(0, 80) || title,
              source: isEaster ? `彩蛋锚点 · #${target.id}` : getSourceLabel(url),
              content,
              isEaster,
            });
          } catch {
            renderError(getSourceLabel(url));
          }
        }

        function shouldPreviewLink(anchor) {
          if (!(anchor instanceof HTMLAnchorElement)) return false;
          if (anchor.closest('.reference-preview-modal')) return false;
          const href = anchor.getAttribute('href') || '';
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return false;

          let url;
          try {
            url = new URL(anchor.href, window.location.href);
          } catch {
            return false;
          }

          if (!url.hash || url.origin !== window.location.origin) return false;
          if (url.pathname !== window.location.pathname && !url.pathname.includes('/posts/')) return false;
          return url;
        }

        function bindReferenceLinks() {
          prose.addEventListener('click', (event) => {
            if (event.defaultPrevented || event.ctrlKey || event.metaKey || event.shiftKey || event.altKey) return;
            const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
            const url = shouldPreviewLink(anchor);
            if (!url) return;
            event.preventDefault();
            openReferencePreview(url, anchor);
          }, { signal });
        }

        function openInitialEasterAnchor() {
          if (!window.location.hash) return;
          const id = decodeURIComponent(window.location.hash.slice(1));
          const target = id ? prose.querySelector(`#${CSS.escape(id)}[data-easter-anchor]`) : null;
          if (!(target instanceof HTMLElement)) return;
          window.setTimeout(() => {
            openReferencePreview(new URL(window.location.href), null);
          }, 120);
        }

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && previewOverlay?.classList.contains('is-open')) {
            closePreview();
          }
        }, { signal });

        enhanceCodeBlocks();
        setupEasterAnchors();
        bindReferenceLinks();
        openInitialEasterAnchor();

        window[cleanupKey] = () => {
          controller.abort();
          closePreview();
          previewOverlay?.remove();
          previewOverlay = null;
        };
      }

      window[initKey] = initPostEnhancements;
      initPostEnhancements();

      if (!window[listenerKey]) {
        window.addEventListener('post-unlocked', () => {
          const init = window[initKey];
          if (typeof init === 'function') init();
        });

        document.addEventListener('astro:page-load', () => {
          const init = window[initKey];
          if (typeof init === 'function') init();
        });
        window[listenerKey] = true;
      }
    })();
  </script>
</BaseLayout>
