---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TagList from '../components/TagList.astro';
import Giscus from '../components/Giscus.astro';
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="container-medium flex-1 pb-12 pt-6 md:pb-16">
    <article class="space-y-8">
      <header class="panel reveal-up overflow-hidden rounded-[40px] px-6 py-8 md:px-10 md:py-12">
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.22em] text-[var(--muted)]">
          <a href="/archive" class="transition hover:text-[var(--accent-strong)]">Archive</a>
          <span class="h-1 w-1 rounded-full bg-[var(--gold)]"></span>
          <span>Published {formatDate(pubDate)}</span>
        </div>
        <h1 class="section-title mt-6 max-w-4xl text-4xl md:text-5xl lg:text-6xl">{title}</h1>
        {description && (
          <p class="mt-5 max-w-3xl text-base leading-8 text-[var(--muted)] md:text-lg">{description}</p>
        )}
        <div class="mt-8 flex flex-wrap items-center gap-5">
          <div class="stat-card min-w-[180px]">
            <p class="stat-label">发布日期</p>
            <p class="mt-2 text-base font-semibold text-[var(--text)]">{formatDate(pubDate)}</p>
          </div>
          {tags.length > 0 && <TagList tags={tags} class="max-w-3xl" />}
        </div>
      </header>
      <div class="panel reveal-up rounded-[32px] px-5 py-6 md:px-8 md:py-8" style="animation-delay: 120ms;">
        <div class="prose">
          <slot />
        </div>
      </div>
      <div class="reveal-up" style="animation-delay: 220ms;">
        <Giscus />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
