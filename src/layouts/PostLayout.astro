---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TagList from '../components/TagList.astro';
import Giscus from '../components/Giscus.astro';
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  locked?: boolean;
  passwordHash?: string;
  passwordHint?: string;
}

const { title, description, pubDate, tags = [], locked = false, passwordHash, passwordHint } = Astro.props;
const isLocked = locked && Boolean(passwordHash);
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="container-medium flex-1 pt-14 pb-16 md:pt-20">
    <article
      class="space-y-14"
      data-locked-post={isLocked ? 'true' : undefined}
      data-lock-key={isLocked ? passwordHash : undefined}
    >
      <header class="panel reveal-up">
        <div class="flex flex-wrap items-center gap-3 font-mono text-[0.72rem] tracking-[0.1em] uppercase text-[var(--muted)]">
          <a href="/archive" class="transition hover:text-[var(--accent)]">Archive</a>
          <span class="opacity-40">/</span>
          <span>{formatDate(pubDate)}</span>
          {isLocked && <span class="lock-mark">Locked</span>}
        </div>
        <h1 class="section-title mt-7 max-w-3xl" style="font-size: clamp(2.2rem, 4.5vw, 3.2rem);">
          {title}
        </h1>
        {description && (
          <p
            class="mt-6 max-w-2xl text-[1.05rem] leading-[1.78] text-[var(--muted-strong)]"
            style="font-family: var(--font-serif); font-style: italic;"
          >
            {description}
          </p>
        )}
        {tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-[var(--rule)]">
            <TagList tags={tags} />
          </div>
        )}
      </header>
      {isLocked && (
        <section
          class="lock-panel panel reveal-up py-10"
          data-lock-panel
          style="animation-delay: 120ms;"
        >
          <p class="eyebrow">Protected Note</p>
          <h2 class="font-display mt-5 text-[1.55rem] text-[var(--text-strong)]">
            输入密码可查看噢～
          </h2>
          {passwordHint && (
            <p
              class="mt-4 text-[0.94rem] leading-relaxed text-[var(--muted-strong)]"
              style="font-family: var(--font-serif); font-style: italic;"
            >
              Hint：{passwordHint}
            </p>
          )}
          <form class="mt-8 flex flex-col gap-5 sm:flex-row sm:items-end" data-lock-form>
            <label class="flex-1">
              <span class="stat-label">Password</span>
              <input
                class="lock-input mt-2"
                type="password"
                name="password"
                placeholder="••••••••"
                autocomplete="current-password"
                required
              />
            </label>
            <button class="btn-primary whitespace-nowrap" type="submit">Unlock →</button>
          </form>
          <p class="lock-message mt-5" data-lock-message aria-live="polite"></p>
        </section>
      )}
      <div
        class="panel reveal-up"
        style="animation-delay: 120ms;"
        data-locked-content={isLocked ? 'true' : undefined}
        hidden={isLocked}
      >
        <div class="prose">
          <slot />
        </div>
      </div>
      <div class="reveal-up pt-6 border-t border-[var(--rule)]" style="animation-delay: 220ms;">
        <p class="eyebrow mb-6">Discussion</p>
        <Giscus />
      </div>
    </article>
  </main>
  <Footer />
  {isLocked && (
    <script is:inline data-astro-rerun>
      (() => {
        const article = document.querySelector('[data-locked-post="true"]');
        const panel = document.querySelector('[data-lock-panel]');
        const content = document.querySelector('[data-locked-content="true"]');
        const form = document.querySelector('[data-lock-form]');
        const message = document.querySelector('[data-lock-message]');
        const expectedHash = article?.getAttribute('data-lock-key') || '';
        const storageKey = `post-unlocked:${location.pathname}:${expectedHash}`;
        const encoder = new TextEncoder();

        function getStoredUnlock() {
          try {
            return sessionStorage.getItem(storageKey) === '1';
          } catch {
            return false;
          }
        }

        function setStoredUnlock() {
          try {
            sessionStorage.setItem(storageKey, '1');
          } catch {
            // Some privacy modes block sessionStorage; unlocking still works for the current page.
          }
        }

        async function sha256(value) {
          const bytes = encoder.encode(value);
          if (!window.crypto?.subtle) {
            throw new Error('WebCrypto is unavailable');
          }
          const hashBuffer = await window.crypto.subtle.digest('SHA-256', bytes);
          return Array.from(new Uint8Array(hashBuffer))
            .map((byte) => byte.toString(16).padStart(2, '0'))
            .join('');
        }

        function unlock() {
          if (content) content.hidden = false;
          if (panel) panel.hidden = true;
          article?.setAttribute('data-locked-post', 'false');
        }

        if (!article || !panel || !content || !form || !expectedHash) return;
        if (form.dataset.lockBound === 'true') return;
        form.dataset.lockBound = 'true';

        if (getStoredUnlock()) {
          unlock();
          return;
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          const formData = new FormData(form);
          const password = String(formData.get('password') ?? '');
          if (!password) return;

          try {
            const digest = await sha256(password);
            if (digest === expectedHash) {
              setStoredUnlock();
              unlock();
            } else if (message) {
              message.textContent = 'Password is incorrect.';
            }
          } catch {
            if (message) {
              message.textContent = 'This browser cannot verify the password here.';
            }
          }
        });
      })();
    </script>
  )}
</BaseLayout>
