---
const navItems = [
  { label: '首页', href: '/' },
  { label: '归档', href: '/archive' },
  { label: '关于', href: '/about' },
];

const normalizePath = (path: string) =>
  path.length > 1 && path.endsWith('/') ? path.slice(0, -1) : path;

const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="container-wide glass-nav">
  <div class="glass-nav-inner">
    <a href="/" class="brand-mark">
      <span class="brand-dot" aria-hidden="true"></span>
      <span>梦付千秋</span>
    </a>
    <div class="nav-cluster">
      <nav class="nav-links">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <button
        class="theme-toggle"
        type="button"
        aria-label="切换深色模式"
        data-theme-toggle
      >
        <svg class="icon-sun" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
        </svg>
        <svg class="icon-moon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
        </svg>
      </button>
      <button
        class="nav-search-trigger"
        type="button"
        data-search-trigger
        aria-haspopup="dialog"
        aria-controls="site-search"
        aria-label="打开搜索"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
        <span>搜索</span>
        <span class="nav-search-kbd">Ctrl K</span>
      </button>
    </div>
  </div>
</header>
