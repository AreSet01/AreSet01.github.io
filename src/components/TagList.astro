---
interface Props {
  tags: string[];
  class?: string;
}

const { tags, class: className = '' } = Astro.props;
---

<div class={`flex flex-wrap gap-2 ${className}`}>
  {tags.map(tag => (
    <span class="text-xs bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full">
      #{tag}
    </span>
  ))}
</div>
