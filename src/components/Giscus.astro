---
/**
 * Giscus 评论组件
 * 使用前需要：
 * 1. 在 GitHub 仓库启用 Discussions
 * 2. 安装 Giscus App: https://github.com/apps/giscus
 * 3. 在 https://giscus.app 获取配置参数
 * 4. 替换下方的 data-repo 等属性
 */
---

<section class="giscus-comments">
  <h3 class="text-lg font-semibold mb-4">评论</h3>
  <script
    src="https://giscus.app/client.js"
    data-repo="你的用户名/你的仓库名"
    data-repo-id="替换为你的 repo id"
    data-category="Announcements"
    data-category-id="替换为你的 category id"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="zh-CN"
    crossorigin="anonymous"
    async
  ></script>
  <noscript>
    <p class="text-gray-500 text-sm">请启用 JavaScript 以查看评论。</p>
  </noscript>
</section>
