---
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  slug: string;
  index?: number;
  locked?: boolean;
}

const { title, description, pubDate, tags = [], slug, index = 0, locked = false } = Astro.props;
const noteNumber = String(index + 1).padStart(2, '0');
---

<article class="reveal-up h-full" style={`animation-delay: ${Math.min(index * 100, 360)}ms;`}>
  <a
    href={`/posts/${slug}`}
    data-post-preview={`/posts/${slug}`}
    class="note-card group"
  >
    <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-1 font-mono text-[0.72rem] tracking-[0.08em] text-[var(--muted)]">
      <span class="whitespace-nowrap">№ {noteNumber}</span>
      <div class="flex items-center gap-3">
        {locked && <span class="lock-mark">Locked</span>}
        <time datetime={pubDate.toISOString()} class="whitespace-nowrap">
          {formatDate(pubDate)}
        </time>
      </div>
    </div>

    <h2 class="font-display mt-5 text-[1.5rem] leading-[1.2] text-[var(--text-strong)] transition duration-300 group-hover:text-[var(--accent)]">
      {title}
    </h2>

    {description && (
      <p
        class="mt-3 text-[0.92rem] leading-relaxed text-[var(--muted-strong)] line-clamp-3"
        style="font-family: var(--font-serif); font-style: italic;"
      >
        {description}
      </p>
    )}

    {tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1">
        {tags.slice(0, 3).map(tag => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}

    <div class="mt-auto flex items-center justify-between gap-3 pt-8">
      <span class="whitespace-nowrap font-mono text-[0.72rem] tracking-[0.16em] uppercase text-[var(--accent)]">
        Read →
      </span>
      <span class="surface-pill shrink-0">
        {String(tags.length).padStart(2, '0')} / TAGS
      </span>
    </div>
  </a>
</article>
