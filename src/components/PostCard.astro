---
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  slug: string;
  index?: number;
}

const { title, description, pubDate, tags = [], slug, index = 0 } = Astro.props;
---

<article class="reveal-up h-full" style={`animation-delay: ${Math.min(index * 100, 360)}ms;`}>
  <a
    href={`/posts/${slug}`}
    class="panel group flex h-full flex-col overflow-hidden rounded-[30px] p-6 transition duration-500 hover:-translate-y-1.5 hover:shadow-[0_28px_60px_rgba(58,37,20,0.16)]"
  >
    <div class="flex items-center justify-between gap-4 text-[0.74rem] font-semibold uppercase tracking-[0.24em] text-[var(--muted)]">
      <span>Note {String(index + 1).padStart(2, '0')}</span>
      <time datetime={pubDate.toISOString()} class="tracking-[0.14em]">
        {formatDate(pubDate)}
      </time>
    </div>
    <h2 class="font-display mt-5 text-2xl leading-tight text-[var(--text)] transition duration-300 group-hover:text-[var(--accent-strong)]">
      {title}
    </h2>
    {description && (
      <p class="mt-4 text-[0.98rem] leading-7 text-[var(--muted)]">{description}</p>
    )}
    {tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2.5">
        {tags.slice(0, 3).map(tag => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}
    <div class="mt-auto flex items-center justify-between pt-8">
      <span class="text-sm font-semibold text-[var(--accent-strong)]">阅读全文</span>
      <span class="rounded-full border border-[var(--border-strong)] bg-white/70 px-3 py-1 text-xs font-semibold text-[var(--muted)]">
        {String(tags.length).padStart(2, '0')} tags
      </span>
    </div>
  </a>
</article>
